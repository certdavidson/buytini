<?xml version="1.0" encoding="utf-8"?><modification>    <name>#</name>    <version>1.0</version>    <link>#</link>    <author>opencartfaq</author>    <code>theme_modification</code>    <file path="catalog/controller/extension/module/{featured,latest,special,best_category,related_categories}.php|catalog/controller/product/{category,compare,manufacturer,product,recent_viewed,search,special,size_chart}.php|catalog/controller/marketing/specials.php|catalog/controller/vendor/vendor.php">        <operation error="skip">            <search index="0"><![CDATA[$data['products'] = array();]]></search>            <add position="after"><![CDATA[            if ($this->customer->isLogged()) {				$this->load->model('account/wishlist');				$wishlist = $this->model_account_wishlist->getWishlist();				$data['wishlist'] = array_column($wishlist, 'product_id');			} else {				$data['wishlist'] = isset($this->session->data['wishlist']) ? $this->session->data['wishlist'] : [];			}			$setting['cart_products'] = array_column($this->cart->getProducts(), 'product_id');            ]]></add>        </operation>    </file>    <!-- cart modifications -->    <file path="catalog/controller/common/cart.php">        <!-- special percentage -->        <operation error="skip">            <search><![CDATA[$data['products'][] = array(]]></search>            <add position="after"><![CDATA[            'stock_status'           => $product['stock_status'],            'stock_status_class'           => $product['stock_status_class'],            ]]></add>        </operation>    </file>    <file path="catalog/language/uk-ua/common/cart.php">        <!-- special percentage -->        <operation error="skip">            <search><![CDATA[// Text]]></search>            <add position="after"><![CDATA[            $_['text_min_total'] = 'Мінімальна сума замовлення %s';            ]]></add>        </operation>    </file>    <file path="catalog/controller/common/{header,footer}.php">        <!-- special percentage -->        <operation error="skip">            <search><![CDATA[$data['scripts']]]></search>            <add position="before"><![CDATA[            $data['tg_link'] = $this->config->get('config_social_telegram');            $data['fb_link'] = $this->config->get('config_social_facebook');            $data['inst_link'] = $this->config->get('config_social_instagram');            $data['tt_link'] = $this->config->get('config_social_tiktok');            $data['x_link'] = $this->config->get('config_social_xcom');            $data['yt_link'] = $this->config->get('config_social_youtube');            ]]></add>        </operation>    </file>    <file path="catalog/controller/common/footer.php">        <!-- special percentage -->        <operation error="skip">            <search><![CDATA[$data['scripts']]]></search>            <add position="before"><![CDATA[            $data['contact_telephone'] = $this->config->get('config_contact_telephone');            $data['contact_telegram'] = $this->config->get('config_contact_telegram');            $data['contact_viber'] = $this->config->get('config_contact_viber');            $data['contact_whatsapp'] = $this->config->get('config_contact_whatsapp');            ]]></add>        </operation>    </file>    <file path="catalog/controller/product/product.php">        <!-- special percentage -->        <operation error="skip">            <search><![CDATA[$data['products'] = array();]]></search>            <add position="before"><![CDATA[            $data['payment_information_id'] = $this->config->get('config_information_payment_id');            $data['return_information_id'] = $this->config->get('config_information_return_id');            ]]></add>        </operation>    </file>    <!-- oc filter button -->    <file path="catalog/view/theme/*/template/product/{category,search,manufacturer_info,special}.twig">        <operation>            <search><![CDATA[<div class="btn-filter"></div>]]></search>            <add position="replace"><![CDATA[              {% if ocfilter_mobile_button %}              <button class="btn btn--filter ocf-mobile" data-ocf="mobile">                  <svg xmlns="http://www.w3.org/2000/svg" width="14.505" height="14.505" viewBox="0 0 14.505 14.505">                      <path id="Контур_71" data-name="Контур 71" d="M17.5,4V5.612H16.7L12.67,11.655V18.5H7.835v-6.85L3.806,5.612H3V4ZM5.743,5.612l3.7,5.556v5.726h1.612V11.167l3.7-5.556Z" transform="translate(-3 -4)" fill="#fff"/>                  </svg>                  {{ button_filter }}              </button>              {% endif %}              ]]></add>        </operation>    </file>    <!-- oc filter button end -->    <file path="catalog/controller/startup/startup.php">        <operation error="skip">            <search><![CDATA[Cart($this->registry));]]></search>            <add position="after"><![CDATA[			require_once DIR_SYSTEM. 'library/product_formatter.php';			$this->registry->set('product_formatter', new ProductFormatter($this->registry));			]]></add>        </operation>    </file></modification>