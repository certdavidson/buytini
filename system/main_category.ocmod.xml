<?xml version="1.0" encoding="utf-8"?>
<modification>
    <name>Main Category (OCStore-style) for default admin</name>
    <code>buytini_main_category</code>
    <version>1.0.0</version>
    <author>buytini</author>
    <link>https://buytini.com</link>

    <!-- ============ MODEL: persist main_category flag (addProduct + editProduct) ============ -->
    <file path="admin/model/catalog/product.php">
        <!-- No index => replaces the INSERT in BOTH addProduct() and editProduct() (identical lines) -->
        <operation>
            <search><![CDATA[$this->db->query("INSERT INTO " . DB_PREFIX . "product_to_category SET product_id = '" . (int)$product_id . "', category_id = '" . (int)$category_id . "'");]]></search>
            <add position="replace"><![CDATA[$this->db->query("INSERT INTO " . DB_PREFIX . "product_to_category SET product_id = '" . (int)$product_id . "', category_id = '" . (int)$category_id . "', main_category = '" . (int)(isset($data['main_category']) && (int)$data['main_category'] == (int)$category_id) . "'");]]></add>
        </operation>

        <!-- New helper to read the current main category id -->
        <operation>
            <search><![CDATA[public function getProductCategories($product_id) {]]></search>
            <add position="before"><![CDATA[	public function getProductMainCategory($product_id) {
		$query = $this->db->query("SELECT category_id FROM " . DB_PREFIX . "product_to_category WHERE product_id = '" . (int)$product_id . "' AND main_category = '1' LIMIT 1");

		return $query->num_rows ? (int)$query->row['category_id'] : 0;
	}

]]></add>
        </operation>
    </file>

    <!-- ============ CONTROLLER: expose product_main_category to the form ============ -->
    <file path="admin/controller/catalog/product.php">
        <operation>
            <search><![CDATA[$this->load->model('catalog/filter');]]></search>
            <add position="before"><![CDATA[		if (isset($this->request->post['main_category'])) {
			$data['product_main_category'] = (int)$this->request->post['main_category'];
		} elseif (isset($this->request->get['product_id'])) {
			$data['product_main_category'] = $this->model_catalog_product->getProductMainCategory($this->request->get['product_id']);
		} else {
			$data['product_main_category'] = 0;
		}

]]></add>
        </operation>
    </file>

    <!-- ============ TEMPLATE: radio to pick the main category among selected ones ============ -->
    <file path="admin/view/template/catalog/product_form.twig">
        <!-- Pre-rendered categories (on load) -->
        <operation>
            <search><![CDATA[<input type="hidden" name="product_category[]" value="{{ product_category.category_id }}"/>]]></search>
            <add position="before"><![CDATA[                        <input type="radio" name="main_category" value="{{ product_category.category_id }}"{% if product_main_category == product_category.category_id %} checked="checked"{% endif %} title="{{ entry_main_category }}"/>]]></add>
        </operation>

        <!-- Categories added live via autocomplete -->
        <operation>
            <search><![CDATA[$('#product-category').append('<div id="product-category' + item['value'] + '"><i class="fa fa-minus-circle"></i> ' + item['label'] + '<input type="hidden" name="product_category[]" value="' + item['value'] + '" /></div>');]]></search>
            <add position="replace"><![CDATA[$('#product-category').append('<div id="product-category' + item['value'] + '"><i class="fa fa-minus-circle"></i> <input type="radio" name="main_category" value="' + item['value'] + '" title="{{ entry_main_category }}" /> ' + item['label'] + '<input type="hidden" name="product_category[]" value="' + item['value'] + '" /></div>');]]></add>
        </operation>
    </file>

    <!-- ============ LANGUAGE: en-gb label (uk-ua already has it; ru-ru admin pack absent) ============ -->
    <file path="admin/language/en-gb/catalog/product.php">
        <operation>
            <search><![CDATA[$_['entry_category']]]></search>
            <add position="after"><![CDATA[$_['entry_main_category']    = 'Main category';
$_['help_main_category']     = 'Select the product\'s main category';]]></add>
        </operation>
    </file>
</modification>
