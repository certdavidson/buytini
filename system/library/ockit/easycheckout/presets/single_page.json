{
    "code": "single_page",
    "name": "Single-page UA",
    "description": "Все на одній сторінці у 2 колонках. Покупець + Адреса + Доставка + Оплата + Кошик.",
    "layout": {
        "mode": "single_step",
        "steps": [
            {
                "id": "step1",
                "title": [],
                "rows": [
                    {
                        "id": "row1", "columns": { "desktop": 1, "tablet": 1 },
                        "cells": [
                            {
                                "id": "cell1",
                                "blocks": [
                                    {
                                        "id": "customer", "type": "customer",
                                        "settings": {
                                            "registration_mode": "optional",
                                            "fields": [
                                                { "field_id": -1, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -2, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -3, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -4, "visibility": "always", "required": true,  "reload_on_change": false }
                                            ]
                                        }
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "row2", "columns": { "desktop": 2, "tablet": 1 },
                        "cells": [
                            {
                                "id": "cell2a",
                                "blocks": [
                                    {
                                        "id": "shipping_address", "type": "shipping_address",
                                        "settings": {
                                            "fields": [
                                                { "field_id": -24, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -26, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -27, "visibility": "always", "required": true,  "reload_on_change": false },
                                                { "field_id": -28, "visibility": "always", "required": true,  "reload_on_change": true  },
                                                { "field_id": -29, "visibility": "always", "required": true,  "reload_on_change": false }
                                            ]
                                        }
                                    },
                                    { "id": "shipping", "type": "shipping", "settings": { "display_mode": "radio", "auto_select_first": true } },
                                    { "id": "payment",  "type": "payment",  "settings": { "display_mode": "radio", "auto_select_first": true } },
                                    { "id": "comment",  "type": "comment" }
                                ]
                            },
                            {
                                "id": "cell2b",
                                "blocks": [
                                    { "id": "cart", "type": "cart", "settings": { "show_image": true, "show_quantity_controls": true, "show_remove_btn": true } }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "row3", "columns": { "desktop": 1, "tablet": 1 },
                        "cells": [
                            {
                                "id": "cell3",
                                "blocks": [
                                    { "id": "agreement",  "type": "agreement", "settings": { "required": true } },
                                    { "id": "buttons__1", "type": "buttons" }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
