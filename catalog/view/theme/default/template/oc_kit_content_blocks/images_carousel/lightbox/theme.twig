{% set bid = block_id ? block_id : 0 %}
{% set pv = params.per_view ?? {} %}
{% set pv_m = pv.mobile  ?? 1 %}
{% set pv_t = pv.tablet  ?? 2 %}
{% set pv_d = pv.desktop ?? 3 %}
<div class="cb-block cb-block--images_carousel cb-block--images_carousel-lightbox {{ css_classes }}"{% if inline_style %} style="{{ inline_style }}"{% endif %} data-block-id="{{ bid }}">
  <div class="swiper cb-swiper" id="cb-icl-{{ bid }}">
    <div class="swiper-wrapper">
      {% for img in images %}
        <div class="swiper-slide cb-block--images_carousel-lightbox__slide">
          <a href="{{ img.data.image }}" class="glightbox cb-block--images_carousel-lightbox__item" data-gallery="cbic-{{ bid }}" data-glightbox="title: {{ img.data.alt ?? '' }}; type: image;">
            <img src="{{ img.image_resized ?? img.data.image }}" alt="{{ img.data.alt ?? '' }}">
            <span class="cb-block--images_carousel-lightbox__zoom" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.5" y2="16.5"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
            </span>
          </a>
        </div>
      {% endfor %}
    </div>
    {% if params.pagination ?? true %}<div class="swiper-pagination"></div>{% endif %}
    {% if params.arrows ?? true %}<div class="swiper-button-prev"></div><div class="swiper-button-next"></div>{% endif %}
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded',function(){if(window.Swiper){new Swiper('#cb-icl-{{ bid }}',{slidesPerView:{{ pv_m }},spaceBetween:14,breakpoints:{576:{slidesPerView:{{ pv_t }},spaceBetween:16},992:{slidesPerView:{{ pv_d }},spaceBetween:18}},navigation:{{ (params.arrows ?? true) ? "{nextEl:'#cb-icl-" ~ bid ~ " .swiper-button-next',prevEl:'#cb-icl-" ~ bid ~ " .swiper-button-prev'}" : 'false' }},pagination:{{ (params.pagination ?? true) ? "{el:'#cb-icl-" ~ bid ~ " .swiper-pagination',clickable:true}" : 'false' }},autoplay:{{ params.autoplay ? '{delay:4500}' : 'false' }},loop:{{ (params.loop ?? false) ? 'true' : 'false' }}});}if(typeof GLightbox!=='undefined'){GLightbox({selector:'.glightbox[data-gallery="cbic-{{ bid }}"]'});}});</script>
