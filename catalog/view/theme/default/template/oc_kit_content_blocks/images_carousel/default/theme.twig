{% set bid = block_id ? block_id : 0 %}
{% set pv = params.per_view ?? {} %}
{% set pv_m = pv.mobile  ?? 2 %}
{% set pv_t = pv.tablet  ?? 4 %}
{% set pv_d = pv.desktop ?? 6 %}
<div class="cb-block cb-block--images_carousel cb-block--images_carousel-default {{ css_classes }}"{% if inline_style %} style="{{ inline_style }}"{% endif %} data-block-id="{{ bid }}">
  <div class="swiper cb-swiper" id="cb-ic-{{ bid }}">
    <div class="swiper-wrapper">
      {% for img in images %}
        <div class="swiper-slide cb-block--images_carousel-default__slide">
          {% if img.data.url %}<a href="{{ img.data.url }}">{% endif %}
          <img src="{{ img.image_resized ?? img.data.image }}" alt="{{ img.data.alt ?? '' }}">
          {% if img.data.url %}</a>{% endif %}
        </div>
      {% endfor %}
    </div>
    {% if params.pagination ?? true %}<div class="swiper-pagination"></div>{% endif %}
    {% if params.arrows ?? true %}<div class="swiper-button-prev"></div><div class="swiper-button-next"></div>{% endif %}
  </div>
</div>
<script>document.addEventListener('DOMContentLoaded',function(){if(window.Swiper){new Swiper('#cb-ic-{{ bid }}',{slidesPerView:{{ pv_m }},spaceBetween:14,breakpoints:{576:{slidesPerView:{{ pv_t }},spaceBetween:18},992:{slidesPerView:{{ pv_d }},spaceBetween:24}},navigation:{{ (params.arrows ?? true) ? "{nextEl:'#cb-ic-" ~ bid ~ " .swiper-button-next',prevEl:'#cb-ic-" ~ bid ~ " .swiper-button-prev'}" : 'false' }},pagination:{{ (params.pagination ?? true) ? "{el:'#cb-ic-" ~ bid ~ " .swiper-pagination',clickable:true}" : 'false' }},autoplay:{{ params.autoplay ? '{delay:3000}' : 'false' }},loop:{{ (params.loop ?? true) ? 'true' : 'false' }}});}});</script>
