<div class="cb-block cb-block--faq cb-block--faq-cards {{ css_classes }}"{% if inline_style %} style="{{ inline_style }}"{% endif %} data-block-id="{{ block_id ? block_id : 0 }}">
  <div class="cb-grid cb-grid-2 cb-gap-5">
    {% for item in items %}
      <div class="cb-block--faq-cards__item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <div class="cb-block--faq-cards__q" itemprop="name">{{ item.data.question }}</div>
        <div class="cb-block--faq-cards__a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <div itemprop="text">{{ item.data.answer }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>
