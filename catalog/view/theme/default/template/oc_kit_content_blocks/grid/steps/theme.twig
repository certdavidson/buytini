<div class="cb-block cb-block--grid cb-block--grid-steps {{ css_classes }}"{% if inline_style %} style="{{ inline_style }}"{% endif %} data-block-id="{{ block_id ? block_id : 0 }}">
  <div class="cb-block--grid-steps__wrap">
    {% for row in rows %}
      <div class="cb-row cb-block--grid-steps__row {{ row.css_classes }}"{% if row.inline_style %} style="{{ row.inline_style }}"{% endif %}>
        {% for col in row.cols %}
          <div class="cb-col cb-col-{{ col.col_width ?? 12 }} cb-block--grid-steps__col {{ col.css_classes }}"{% if col.inline_style %} style="{{ col.inline_style }}"{% endif %}>
            <div class="cb-block--grid-steps__num" aria-hidden="true">{{ '%02d'|format(loop.index) }}</div>
            <div class="cb-block--grid-steps__body">
              {% if col.title %}<div class="cb-block--grid-steps__title">{{ col.title }}</div>{% endif %}
              {% include 'default/template/oc_kit_content_blocks/partials/elements.twig' with { elements: col.elements_data } only %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>
