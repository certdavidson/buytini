<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<base href="{{ base }}" />
{% if description %}
<meta name="description" content="{{ description }}" />
{% endif %}
{% if keywords %}
<meta name="keywords" content="{{ keywords }}" />
{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css">
<link rel="stylesheet" href="/catalog/view/theme/default/assets/css/main.css">

{% for style in styles %}
<link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}" />
{% endfor %}
{% for script in scripts %}
<script src="{{ script }}" type="text/javascript"></script>
{% endfor %}

{% for link in links %}
<link href="{{ link.href }}" rel="{{ link.rel }}" />
{% endfor %}
{% for analytic in analytics %}
{{ analytic }}
{% endfor %}

<script>(function(){try{var t=localStorage.getItem('buytini-theme');if(!t){t=(window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches)?'dark':'light';}document.documentElement.setAttribute('data-theme',t);}catch(e){document.documentElement.setAttribute('data-theme','light');}})();</script>
</head>
<body>
<div class="site-header">

  <!-- Службовий верхній рядок -->
  <div class="topbar" id="topbar">
    <div class="topbar__inner">
      <nav class="topbar__nav" aria-label="Службові посилання">
        <a class="topbar__link" href="how-it-works.html">Як це працює</a>
        <a class="topbar__link" href="delivery.html">Доставка та мита</a>
        <a class="topbar__link" href="buyout.html">Викуп</a>
        <a class="topbar__link" href="contacts.html">Контакти</a>
      </nav>
      <div class="topbar__side">
        <a class="topbar__email" href="mailto:hello@buytini.ua">hello@buytini.ua</a>
        <div class="topbar__socials">
          <a class="topbar__social" href="#" aria-label="Instagram"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg></a>
          <a class="topbar__social" href="#" aria-label="Telegram"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21.9 4.3 18.7 19.4c-.2 1-.9 1.3-1.7.8l-4.7-3.5-2.3 2.2c-.3.3-.5.5-1 .5l.4-4.9 8.9-8c.4-.3-.1-.5-.6-.2L6.9 13.4l-4.7-1.5c-1-.3-1-1 .2-1.5l18.3-7c.9-.3 1.6.2 1.2 1.9z"></path></svg></a>
          <a class="topbar__social" href="#" aria-label="TikTok"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16.5 3c.3 2.2 1.6 3.6 3.7 3.8v2.5c-1.3.1-2.5-.3-3.7-1v5.9c0 4-3.2 6.5-6.6 5.4-2.6-.8-3.7-3.8-2.5-6.2.9-1.8 2.9-2.7 4.9-2.4v2.6c-.4-.1-.8-.2-1.2-.1-1 .1-1.7 1-1.6 2 .1 1.4 1.7 2 2.8 1.2.6-.4.8-1 .8-1.8V3h2.4z"></path></svg></a>
          <a class="topbar__social" href="#" aria-label="YouTube"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path><path d="m10 15 5-3-5-3z"></path></svg></a>
        </div>
      </div>
    </div>
  </div>

  <!-- Основна шапка -->
  <header class="header">
    <div class="header__inner">

      <a class="header__logo" href="index.html">
        <img class="header__logo-img" src="/catalog/view/theme/default/assets/images/buytini-logo.svg" alt="buytini" width="40" height="42">
        <span class="header__logo-text">buytini</span>
      </a>

      <button class="catalog-btn" type="button" data-toggle="mega" aria-label="Каталог">
        <span class="catalog-btn__open"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg></span>
        <span class="catalog-btn__close"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg></span>
        <span class="catalog-btn__label">Каталог</span>
      </button>

      {{ search }}

      <!-- Праві дії -->
      <div class="header__actions">

        <button class="icon-btn" type="button" data-toggle="theme" aria-label="Перемкнути тему">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
        </button>

        {{ language }}

        {{ currency }}

        <button class="icon-btn" type="button" data-open="auth" aria-label="Акаунт">
          <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </button>

        <!-- Обране -->
        <a class="icon-btn" href="wishlist.html" aria-label="Обране">
          <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path></svg>
          <span class="icon-btn__badge">2</span>
        </a>

        {{ cart }}
        
      </div>
    </div>
  </header>

  {# Затемнення під пошук #}
  <div class="overlay overlay--search" id="search-overlay" data-popover="" hidden=""></div>

  {{ cart_popup }}

  {{ menu }}

  <!-- Модалка авторизації -->
  <div class="overlay overlay--auth" id="auth-modal" data-popover="" hidden="">
    <div class="auth" role="dialog" aria-label="Вхід в акаунт">
      <div class="auth__head">
        <div>
          <span class="auth__title">Вхід в акаунт</span>
          <span class="auth__sub">Увійдіть, щоб заповнення даних було автоматичним</span>
        </div>
        <button class="auth__close" type="button" data-close="" aria-label="Закрити"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg></button>
      </div>

      <div class="auth__tabs">
        <button class="auth__tab is-active" type="button" data-auth-tab="phone">За номером</button>
        <button class="auth__tab" type="button" data-auth-tab="email">Email + пароль</button>
      </div>

      <form class="auth__body" data-form="auth">
        <div class="auth__method is-active" data-auth-method="phone">
          <label class="field__label">Номер телефону</label>
          <input class="input" type="tel" placeholder="+380 (XX) XXX-XX-XX">
          <button class="btn btn--dark btn--block" type="submit">Отримати код в SMS</button>
        </div>
        <div class="auth__method" data-auth-method="email">
          <label class="field__label">Email</label>
          <input class="input" type="email" placeholder="you@example.com">
          <label class="field__label">Пароль</label>
          <input class="input" type="password" placeholder="••••••••">
          <button class="btn btn--dark btn--block" type="submit">Увійти</button>
        </div>

        <div class="auth__divider"><span></span><span>або</span><span></span></div>

        <button class="auth__social" type="button"><svg width="18" height="18" viewBox="0 0 48 48"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"></path><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"></path><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"></path><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"></path></svg>Увійти через Google</button>

        <p class="auth__foot">Ще не маєте акаунту? <a href="register.html">Зареєструватися</a></p>
      </form>
    </div>
  </div>
</div>