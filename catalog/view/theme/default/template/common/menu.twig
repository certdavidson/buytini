<div class="overlay" id="mega-overlay" data-popover="" hidden=""></div>
<div class="mega" id="mega" data-popover="" hidden="" role="dialog" aria-label="Каталог">
  <div class="container">
    <div class="mega__head"><span>Каталог товарів</span><button class="panel-close" type="button" data-toggle="mega"
        aria-label="Закрити"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg></button></div>
    <div class="mega__back"><button class="mega__back-btn" type="button" data-mega-back="" aria-label="Назад"><svg
          width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg></button><span class="mega__back-title">Каталог</span></div>

    <div class="mega__layout">
      <div class="mega__rail">
        {% for key,category in categories %}
        <button class="mega__cat{% if key == 0 %} is-active{% endif %}" type="button" data-mega-cat="{{ key }}">
          <span class="mega__cat-label">
            <img class="mega__cat-icon" width="18" height="18" src="/{{ category.icon }}" alt="{{ category.name }}">
            {{ category.name }}</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
        {% endfor %}

      </div>

       {% for key,category in categories %}
      <div class="mega__groups mega__panel{% if key == 0 %} is-active{% endif %}" data-mega-panel="{{ key }}">
        {% for children in category.children|batch(category.children|length / 4) %}
        <div>
          {% for child in children %}

          <a class="mega__group-title" href="{{ child.href }}">{{ child.name }}</a>
          {% if child.children %}
          {% for grandchild in child.children %}
          <a class="mega__sub" href="{{ grandchild.href }}">{{ grandchild.name }}</a>
          {% endfor %}
          {% endif %}

          {% endfor %}
        </div>
        {% endfor %}
      </div>
      {% endfor %}
      
      <!-- Бренди -->
      <div class="mega__groups mega__panel" data-mega-panel="5">
        <div><span class="mega__group-title">США</span><a class="mega__sub" href="brand.html">Nike</a><a
            class="mega__sub" href="brand.html">Levi’s</a><a class="mega__sub" href="brand.html">Lacoste</a><a
            class="mega__sub" href="brand.html">Coach</a><a class="mega__sub" href="brand.html">Michael Kors</a></div>
        <div><span class="mega__group-title">Європа</span><a class="mega__sub" href="brand.html">Rituals</a><a
            class="mega__sub" href="brand.html">Armani Exchange</a><a class="mega__sub" href="brand.html">JW Pei</a><a
            class="mega__sub" href="brand.html">Versace</a></div>
      </div>
      <!-- Акції -->
      <div class="mega__groups mega__panel" data-mega-panel="6">
        <div><span class="mega__group-title">Розпродаж</span><a class="mega__sub" href="sale.html">До -50%</a><a
            class="mega__sub" href="sale.html">Останні розміри</a><a class="mega__sub" href="sale.html">Аутлет</a></div>
        <div><span class="mega__group-title">Сезон</span><a class="mega__sub" href="sale.html">Літній сейл</a><a
            class="mega__sub" href="sale.html">Чорна п’ятниця</a></div>
      </div>
    </div>
  </div>
</div>