<div class="d-card">
    <a class="d-card__media" href="product.html" style="background-image:url({{ product.thumb }})">
        <span class="d-card__badge d-card__badge--sale">{{ product.discount }}-10%</span>
        <button class="d-card__wish" type="button" aria-label="В обране">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            </svg>
        </button>
    </a>
    <div class="d-card__body">
        <span class="d-card__brand">{{ product.manufacturer }}</span>
        <span class="d-card__name">{{ product.name }}</span>
        {% if product.options %}
        {% for option in product.options %}
        {% if option.option_id == 1 %}
        <div class="d-card__colors">
            {% for option_value in option.values %}
            <span class="d-card__color" style="background:#{{ option_value.color }}"></span>
            {% endfor %}
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}
        <div class="d-card__foot">
            <div class="d-card__prices">
                {% if product.special %}
                    <span class="d-card__price">{{ product.special }}</span>
                    <span class="d-card__price-old">{{ product.price }}</span>
                {% else %}
                    <span class="d-card__price">{{ product.price }}</span>
                {% endif %}
            </div>
            <button class="d-card__add" type="button" aria-label="{{ button_cart }}">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 4h2l2.4 12.5a1 1 0 0 0 1 .8h9.2a1 1 0 0 0 1-.8L21 8H6" />
                    <circle cx="9.5" cy="20" r="1.3" />
                    <circle cx="17.5" cy="20" r="1.3" />
                </svg>
            </button>
        </div>
    </div>
    {% if product.options %}
    <div class="d-opts">
        {% for option in product.options %}
        <span class="d-opts__label">{{ option.name }}</span>
        <div class="d-opts__list">
            {% for option_value in option.values %}
            <span class="d-opt">{{ option_value }}</span>
            {% endfor %}
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>