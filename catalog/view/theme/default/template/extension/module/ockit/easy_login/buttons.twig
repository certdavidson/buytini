<script>window.elI18n = {{ js_i18n|json_encode }};</script>
<div class="el-buttons" data-el-context="{{ context }}" data-el-return="{{ return_url }}" data-el-link="{{ link_mode ? '1' : '0' }}">

  {% set show_google   = google_enabled   and google_mode in ['button', 'both'] and 'google'   not in linked_providers %}
  {% set show_facebook = facebook_enabled and 'facebook' not in linked_providers %}
  {% set show_apple    = apple_enabled    and 'apple'    not in linked_providers %}
  {% set show_telegram = telegram_enabled and 'telegram' not in linked_providers %}
  {% set show_magic    = email_magic_enabled and not hide_passwordless %}
  {% set show_sms      = sms_otp_enabled     and not hide_passwordless %}
  {% set any_oauth     = show_google or show_facebook or show_apple or show_telegram %}

  {% if show_magic or show_sms or any_oauth %}

    {% if show_magic %}
    <div class="el-magic">
      <input type="email" class="form-control el-input" id="el-magic-email" placeholder="{{ placeholder_email }}">
      <button type="button" class="btn btn-primary w-100" id="el-magic-send" data-url="{{ urls.magic_send }}">
        <span class="el-label">{{ button_send_magic }}</span>
      </button>
      <div class="el-msg" id="el-magic-msg"></div>
    </div>
    {% endif %}

    {% if show_sms %}
    <div class="el-sms" data-el-step="phone">
      <div class="el-sms-step el-sms-step-phone form-group">
        <label for="el-sms-phone" class="form-label">{{ entry_phone }}</label>
        <input type="tel" class="form-control mb-2 el-phone-mask" id="el-sms-phone" placeholder="{{ placeholder_phone }}" inputmode="tel">
        <button type="button" class="btn btn-primary w-100" id="el-sms-send" data-url="{{ urls.sms_send }}">
          <span class="el-label">{{ button_send_sms_code }}</span>
        </button>
      </div>
      <div class="el-sms-step el-sms-step-code mt-3" hidden>
        <input type="text" class="form-control mb-2" id="el-sms-code" maxlength="{{ sms_otp_code_length }}" placeholder="{{ sms_otp_code_placeholder }}">
        <button type="button" class="btn btn-primary w-100" id="el-sms-verify" data-url="{{ urls.sms_verify }}">
          <span class="el-label">{{ button_verify }}</span>
        </button>
      </div>
      <div class="el-msg" id="el-sms-msg"></div>
    </div>
    {% endif %}

    {% if any_oauth and (show_magic or show_sms) %}
    <div class="el-divider"><span>{{ text_or }}</span></div>
    {% endif %}

    {% if any_oauth %}
    <div class="el-providers">
      {% if show_google %}
      <a href="{{ urls.google_redirect }}" class="el-btn el-btn-google el-btn-{{ google_button_theme }}">
        <span class="el-icon"><svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/><path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.26c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z" fill="#34A853"/><path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/><path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/></g></svg></span>
        <span class="el-label">{{ button_continue_google }}</span>
      </a>
      {% endif %}

      {% if show_facebook %}
      <a href="{{ urls.facebook_redirect }}" class="el-btn el-btn-facebook">
        <span class="el-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></span>
        <span class="el-label">{{ button_continue_facebook }}</span>
      </a>
      {% endif %}

      {% if show_apple %}
      <a href="{{ urls.apple_redirect }}" class="el-btn el-btn-apple el-btn-{{ apple_button_theme }}">
        <span class="el-icon"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg></span>
        <span class="el-label">{{ button_continue_apple }}</span>
      </a>
      {% endif %}

      {% if show_telegram %}
      <div class="el-btn-telegram-wrap" data-el-tg-bot="{{ telegram_bot_username }}" data-el-tg-size="{{ telegram_button_size }}" data-el-tg-phone="{{ telegram_request_phone ? '1' : '0' }}" data-el-tg-callback="{{ urls.telegram_callback }}"></div>
      {% endif %}
    </div>
    {% endif %}

  {% endif %}

</div>
