<div class="okec-block__inner okec-block-buttons{% if block.settings.sticky_on_mobile %} okec-block-buttons--sticky-mobile{% endif %}">
  <button type="button" class="btn btn-primary okec-block-buttons__submit" data-okec-action="confirm">
    <svg class="okec-block-buttons__icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span data-okec-submit-label>{% if block.settings.submit_text %}{{ block.settings.submit_text }}{% else %}{{ text_place_order }}{% endif %}</span>
    <span class="okec-block-buttons__amount" data-okec-submit-amount></span>
  </button>
</div>
