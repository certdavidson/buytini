<div class="okec-block__inner okec-block-shipping" data-okec-shipping-container>
  {# Поля адреси, потрібні модулям доставки (НП-warehouse, address_1) #}
  {% if block.settings.fields|length > 0 %}
    {% include template_dir ~ 'easycheckout/blocks/_fields_list.twig' %}
  {% endif %}
  {# Список варіантів доставки — підвантажується JS у Stage 4.3 #}
  <div class="okec-block-shipping__methods" data-okec-methods="shipping"
       data-display-mode="{{ block.settings.display_mode }}"
       data-auto-select="{{ block.settings.auto_select_first ? '1' : '0' }}"
       data-show-description="{{ block.settings.show_description ? '1' : '0' }}">
    <p class="okec-block-shipping__placeholder">Shipping methods will load here…</p>
  </div>
</div>
