{{ header }}
<main class="state">
  <div class="state__inner">
    <span class="state__icon state__icon--muted"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></span>
    <div class="state__code">404</div>
    <h1 class="state__title">{{ heading_title }}</h1>
    <p class="state__text">{{ text_error }}</p>
    <div class="state__actions"><a class="btn btn--primary state__btn" href="{{ continue }}">{{ button_continue }}</a></div>
  </div>
</main>
{{ footer }}
