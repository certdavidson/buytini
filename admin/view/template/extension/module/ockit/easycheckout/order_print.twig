{# EasyCheckout — Order print | © 2026 oc-kit.com | https://oc-kit.com #}
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Order #{{ order.order_id }} — {{ store_name }}</title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;
           font-size: 13px; color: #2c3e50; max-width: 780px; margin: 20px auto; padding: 0 16px; }
    h1 { font-size: 20px; margin: 0 0 4px; }
    h2 { font-size: 14px; margin: 18px 0 8px; padding-bottom: 4px; border-bottom: 1px solid #e0e4eb; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    th, td { padding: 8px 10px; border: 1px solid #e0e4eb; text-align: left; vertical-align: top; }
    th { background: #f4f6f9; font-weight: 600; }
    .meta { display: flex; justify-content: space-between; margin-bottom: 14px; }
    .meta__col { flex: 1; }
    .meta__label { color: #8a94a6; font-size: 11px; }
    .totals td:last-child { text-align: right; font-weight: 600; }
    .totals tr:last-child td { font-size: 14px; border-top: 2px solid #2c3e50; }
    .print-btn { background: #1976d2; color: #fff; border: 0; padding: 8px 14px;
                 border-radius: 4px; cursor: pointer; font-size: 13px; }
    @media print {
      .no-print { display: none; }
      body { margin: 0; }
    }
  </style>
</head>
<body>

<div class="no-print" style="text-align:right; margin-bottom: 12px;">
  <button type="button" class="print-btn" onclick="window.print()">🖨 Print</button>
</div>

<h1>{{ store_name }}</h1>
<p class="meta__label">{{ store_url }}</p>

<h2>Order #{{ order.order_id }}</h2>

<div class="meta">
  <div class="meta__col">
    <div class="meta__label">Customer</div>
    <strong>{{ order.firstname }} {{ order.lastname }}</strong><br>
    {{ order.email }}<br>
    {{ order.telephone }}
  </div>
  <div class="meta__col">
    <div class="meta__label">Shipping</div>
    {{ order.shipping_firstname }} {{ order.shipping_lastname }}<br>
    {{ order.shipping_company }}<br>
    {{ order.shipping_address_1 }} {{ order.shipping_address_2 }}<br>
    {{ order.shipping_city }} {{ order.shipping_postcode }}<br>
    {{ order.shipping_zone }}, {{ order.shipping_country }}
  </div>
  <div class="meta__col">
    <div class="meta__label">Payment</div>
    {{ order.payment_method }}<br>
    <span class="meta__label">Date</span><br>
    {{ order.date_added }}
  </div>
</div>

<h2>Items</h2>
<table>
  <thead>
    <tr>
      <th>Product</th>
      <th style="width:90px;">Model</th>
      <th style="width:60px;text-align:center;">Qty</th>
      <th style="width:90px;text-align:right;">Price</th>
      <th style="width:110px;text-align:right;">Total</th>
    </tr>
  </thead>
  <tbody>
    {% for p in products %}
    <tr>
      <td>{{ p.name }}</td>
      <td>{{ p.model }}</td>
      <td style="text-align:center;">{{ p.quantity }}</td>
      <td style="text-align:right;">{{ p.price }}</td>
      <td style="text-align:right;">{{ p.total }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<h2>Totals</h2>
<table class="totals">
  {% for t in totals %}
  <tr>
    <td>{{ t.title }}</td>
    <td style="text-align:right;">{{ t.text }}</td>
  </tr>
  {% endfor %}
</table>

{% if custom_fields|length > 0 %}
<h2>EasyCheckout fields</h2>
<table>
  {% for f in custom_fields %}
  <tr>
    <th style="width:30%;">{{ f.name }}</th>
    <td>{{ f.value }}</td>
  </tr>
  {% endfor %}
</table>
{% endif %}

{% if order.comment %}
<h2>Comment</h2>
<p>{{ order.comment|nl2br }}</p>
{% endif %}

</body>
</html>
