{# EasyCheckout | © 2026 oc-kit.com | https://oc-kit.com #}
<h2 class="ok-section-title">{{ restrictions_heading }}</h2>
<p class="ok-help">{{ restrictions_help }}</p>

<div x-data="okecRestrictions()" x-init="load()">
  <div class="okec-loading" x-show="loading"><i data-lucide="loader" class="okec-spin"></i></div>

  <div class="ok-panel" x-show="!loading && items.length > 0" x-cloak>
    <div class="ok-panel-header"><span><i data-lucide="shield"></i> {{ restrictions_heading }}</span></div>
    <div class="ok-table-wrap">
    <table class="ok-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>{{ restrictions_col_groups }}</th>
          <th>{{ restrictions_col_total }}</th>
          <th>{{ restrictions_col_qty }}</th>
          <th>{{ restrictions_col_weight }}</th>
          <th>{{ restrictions_col_error }}</th>
          <th class="okec-col-actions"></th>
        </tr>
      </thead>
      <tbody>
        <template x-for="r in items" :key="r.restriction_id">
          <tr>
            <td x-text="r.restriction_id"></td>
            <td><code class="ok-code" x-text="r.customer_group_ids || '*'"></code></td>
            <td><span x-text="rangeLabel(r.min_total, r.max_total)"></span></td>
            <td><span x-text="rangeLabel(r.min_qty, r.max_qty)"></span></td>
            <td><span x-text="rangeLabel(r.min_weight, r.max_weight)"></span></td>
            <td><small class="ok-muted" x-text="(r.error_text || '').slice(0, 60)"></small></td>
            <td class="okec-col-actions">
              <button type="button" class="ok-btn ok-btn-default ok-btn-xs" @click="openEdit(r)" :title="t('button_edit')">
                <i data-lucide="pencil"></i>
              </button>
              <button type="button" class="ok-btn ok-btn-danger ok-btn-xs" @click="del(r)" :title="t('button_delete')">
                <i data-lucide="trash-2"></i>
              </button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
    </div>
  </div>

  <div class="okec-empty" x-show="!loading && items.length === 0" x-cloak>
    <p>{{ restrictions_empty }}</p>

    <button type="button" class="ok-btn ok-btn-primary ok-mt-3" @click="openCreate()">
      <i data-lucide="plus"></i> {{ button_add_restriction }}
    </button>
  </div>

  

  {# Modal #}
  <div class="okec-modal" x-show="modalOpen" x-cloak @keydown.escape.window="modalOpen = false">
    <div class="okec-modal__backdrop" @click="modalOpen = false"></div>
    <div class="okec-modal__dialog">
      <div class="okec-modal__header">
        <h3><i data-lucide="shield"></i> <span x-text="form.restriction_id ? t('button_edit') : t('button_add')"></span></h3>
        <button type="button" class="okec-modal__close" @click="modalOpen = false"><i data-lucide="x"></i></button>
      </div>
      <div class="okec-modal__body">
        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_col_groups }}</label>
          <div class="ok-form-control">
            <div class="ok-multitag" @click.outside="groupPickerOpen = false">
              <div class="ok-multitag-inner" @click="groupPickerOpen = true">
                <template x-for="id in parseGroups(form.customer_group_ids)" :key="id">
                  <span class="ok-multitag-tag">
                    <span x-text="groupName(id)"></span>
                    <span class="ok-multitag-tag-remove" @click.stop="removeGroup(id)">×</span>
                  </span>
                </template>
                <input type="text" class="ok-multitag-input" readonly
                       :placeholder="parseGroups(form.customer_group_ids).length === 0 ? '{{ restrictions_groups_placeholder }}' : ''">
              </div>
              <div class="ok-multitag-dropdown" :class="{ 'open': groupPickerOpen }">
                <template x-for="g in customerGroups" :key="g.customer_group_id">
                  <div class="ok-multitag-option"
                       :class="{ 'is-selected': hasGroup(g.customer_group_id) }"
                       @click="toggleGroup(g.customer_group_id)">
                    <input type="checkbox" :checked="hasGroup(g.customer_group_id)" @click.stop="toggleGroup(g.customer_group_id)">
                    <span x-text="g.name"></span>
                  </div>
                </template>
              </div>
            </div>
            <p class="ok-help">{{ restrictions_help_groups }}</p>
          </div>
        </div>

        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_label_total }}</label>
          <div class="ok-form-control okec-range-row">
            <input type="text" inputmode="decimal" step="0.01" class="ok-input" x-model="form.min_total" placeholder="min">
            <span>—</span>
            <input type="text" inputmode="decimal" step="0.01" class="ok-input" x-model="form.max_total" placeholder="max">
          </div>
        </div>
        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_label_qty }}</label>
          <div class="ok-form-control okec-range-row">
            <input type="text" inputmode="decimal" step="1" class="ok-input" x-model="form.min_qty" placeholder="min">
            <span>—</span>
            <input type="text" inputmode="decimal" step="1" class="ok-input" x-model="form.max_qty" placeholder="max">
          </div>
        </div>
        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_label_weight }}</label>
          <div class="ok-form-control okec-range-row">
            <input type="text" inputmode="decimal" step="0.01" class="ok-input" x-model="form.min_weight" placeholder="min">
            <span>—</span>
            <input type="text" inputmode="decimal" step="0.01" class="ok-input" x-model="form.max_weight" placeholder="max">
          </div>
        </div>

        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_col_error }}</label>
          <div class="ok-form-control">
            <textarea class="ok-input" rows="3" x-model="form.error_text"></textarea>
            <p class="ok-help">{{ restrictions_help_error }}</p>
          </div>
        </div>

        <div class="ok-form-row">
          <label class="form-label">{{ restrictions_label_sort }}</label>
          <div class="ok-form-control">
            <input type="text" inputmode="decimal" class="ok-input" x-model.number="form.sort_order">
          </div>
        </div>
      </div>
      <div class="okec-modal__footer">
        <button type="button" class="ok-btn ok-btn-default" @click="modalOpen = false">{{ button_cancel }}</button>
        <button type="button" class="ok-btn ok-btn-primary" @click="save()">{{ button_save }}</button>
      </div>
    </div>
  </div>
</div>
