{# SEO Core — sidebar navigation #}
<div class="ok-sidebar">
  <div class="ok-brand">
    <div class="ok-brand-icon"><i data-lucide="search-check"></i></div>
    <a href="https://oc-kit.com" target="_blank" class="ok-brand-logo">oc-kit.com</a>
    <span class="ok-brand-name">SEO Core <span class="ok-brand-version">v{{ module_version }}</span></span>
  </div>
  <div class="ok-tabs-sidebar">
    <button type="button" class="ok-tabs-sidebar-item active" data-tab="layout-dashboard">
      <i data-lucide="bar-chart-2"></i> {{ tab_dashboard }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-settings">
      <i data-lucide="settings-2"></i> {{ tab_settings }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-urls">
      <i data-lucide="link"></i> {{ tab_urls }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-redirects">
      <i data-lucide="arrow-right-left"></i> {{ tab_redirects }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-meta">
      <i data-lucide="tag"></i> {{ tab_meta }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-home">
      <i data-lucide="home"></i> {{ tab_home }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-canonical">
      <i data-lucide="anchor"></i> {{ tab_canonical }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-hreflang">
      <i data-lucide="languages"></i> {{ tab_hreflang }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-opengraph">
      <i data-lucide="share-2"></i> {{ tab_opengraph }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-schema">
      <i data-lucide="boxes"></i> {{ tab_schema }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-headers">
      <i data-lucide="shield"></i> {{ tab_headers }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-audit">
      <i data-lucide="search"></i> {{ tab_audit }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-google">
      <i data-lucide="chrome"></i> {{ tab_google }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-robots">
      <i data-lucide="file-text"></i> {{ tab_robots }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-sitemap">
      <i data-lucide="map"></i> {{ tab_sitemap }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-absurl">
      <i data-lucide="replace"></i> {{ tab_absurl }}
    </button>
    <hr class="ok-divider">
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-faq">
      <i data-lucide="circle-help"></i> {{ tab_faq }}
    </button>
    <button type="button" class="ok-tabs-sidebar-item" data-tab="layout-license">
      <i data-lucide="key"></i> {{ tab_license }}
    </button>
  </div>
</div>
