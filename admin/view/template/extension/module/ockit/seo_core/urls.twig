{# SEO Core | © 2026 oc-kit.com | https://oc-kit.com #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="container-fluid">
    <div class="oc-kit">
      <div class="ok-panel ok-panel-sticky">

        <div class="ok-panel-header">
          <ul class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}
          </ul>
          <div class="ok-flex ok-gap-8">
            <button type="button" id="ok-url-add" class="ok-btn ok-btn-primary ok-btn-sm">
              <i data-lucide="plus"></i> {{ button_add }}
            </button>
            <button type="button" id="ok-url-regen" class="ok-btn ok-btn-default ok-btn-sm">
              <i data-lucide="refresh-cw"></i> {{ button_regen }}
            </button>
          </div>
        </div>

        <div class="ok-layout">
          {% include 'extension/module/ockit/seo_core/_nav.twig' %}

          <div class="ok-content">

            <div class="ok-filter-bar">
              <input type="text" id="ok-url-search" class="ok-input" placeholder="keyword / query...">
              <select id="ok-url-filter-lang" class="ok-select ok-filter-select">
                <option value="">{{ text_all_langs }}</option>
                {% for lang in languages %}
                <option value="{{ lang.language_id }}">{{ lang.name }}</option>
                {% endfor %}
              </select>
            </div>

            <table class="ok-table">
              <thead>
                <tr>
                  <th>Keyword</th>
                  <th>Query</th>
                  <th class="ok-col-sm">{{ label_regen_lang }}</th>
                  <th class="ok-col-sm">Store</th>
                  <th class="ok-col-actions"></th>
                </tr>
              </thead>
              <tbody id="ok-url-tbody">
                <tr><td colspan="5" class="text-center ok-loading">{{ text_loading }}</td></tr>
              </tbody>
            </table>

            <div id="ok-url-pagination" class="ok-pagination"></div>

          </div>{# /ok-content #}
        </div>{# /ok-layout #}
      </div>{# /ok-panel #}

      {# ── Add/Edit modal ── #}
      <div id="ok-url-modal" class="ok-modal-backdrop" style="display:none">
        <div class="ok-modal">
          <div class="ok-modal-header">
            <span id="ok-url-modal-title">SEO URL</span>
            <button type="button" id="ok-url-modal-close" class="ok-modal-close"><i data-lucide="x"></i></button>
          </div>
          <div class="ok-modal-body">
            <input type="hidden" id="ok-url-edit-id" value="0">
            <div class="mb-3">
              <label class="ok-label form-label">Keyword (slug)</label>
              <input type="text" id="ok-url-edit-keyword" class="ok-input" placeholder="nazva-tovaru">
            </div>
            <div class="mb-3">
              <label class="ok-label form-label">Query</label>
              <input type="text" id="ok-url-edit-query" class="ok-input" placeholder="product_id=42">
            </div>
            <div class="mb-3">
              <label class="ok-label form-label">{{ label_regen_lang }}</label>
              <select id="ok-url-edit-lang" class="ok-select">
                {% for lang in languages %}
                <option value="{{ lang.language_id }}">{{ lang.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="ok-modal-footer">
            <button type="button" id="ok-url-modal-save" class="ok-btn ok-btn-primary">{{ button_save }}</button>
            <button type="button" id="ok-url-modal-cancel" class="ok-btn ok-btn-default">{{ button_cancel }}</button>
          </div>
        </div>
      </div>

    </div>{# /oc-kit #}
  </div>
</div>
{{ footer }}

<script>
window.seoCoreConfig = {
  urlsListUrl:  '{{ urls_list_url }}',
  urlSaveUrl:   '{{ url_save_url }}',
  urlDeleteUrl: '{{ url_delete_url }}',
  userToken:    '{{ user_token }}'
};
window.seoCoreI18n = {{ lang_js }};
lucide.createIcons();
</script>
