{# SEO Core | © 2026 oc-kit.com | https://oc-kit.com #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="container-fluid">
    <div class="oc-kit">
      <div class="ok-panel ok-panel-sticky">

        <div class="ok-panel-header">
          <ul class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}
          </ul>
        </div>

        <div class="ok-layout">
          {% include 'extension/module/ockit/seo_core/_nav.twig' %}

          <div class="ok-content">

            {# ── Stats row ── #}
            <div class="ok-stats-row">

              <div class="ok-stat-card">
                <div class="ok-stat-icon"><i data-lucide="link"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-seo-urls">—</div>
                  <div class="ok-stat-label">{{ text_stat_seo_urls }}</div>
                </div>
              </div>

              <div class="ok-stat-card">
                <div class="ok-stat-icon"><i data-lucide="arrow-right-left"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-redirects">—</div>
                  <div class="ok-stat-label">{{ text_stat_redirects }}</div>
                </div>
              </div>

              <div class="ok-stat-card ok-stat-card-error">
                <div class="ok-stat-icon"><i data-lucide="circle-x"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-audit-errors">—</div>
                  <div class="ok-stat-label">{{ text_stat_audit_errors }}</div>
                </div>
              </div>

              <div class="ok-stat-card ok-stat-card-warning">
                <div class="ok-stat-icon"><i data-lucide="triangle-alert"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-audit-warnings">—</div>
                  <div class="ok-stat-label">{{ text_stat_audit_warnings }}</div>
                </div>
              </div>

              <div class="ok-stat-card">
                <div class="ok-stat-icon"><i data-lucide="mouse-pointer-click"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-redirect-hits">—</div>
                  <div class="ok-stat-label">{{ text_stat_redirect_hits }}</div>
                </div>
              </div>

              <div class="ok-stat-card ok-stat-card-alert ok-hidden" id="stat-chains-card">
                <div class="ok-stat-icon"><i data-lucide="alert-triangle"></i></div>
                <div class="ok-stat-body">
                  <div class="ok-stat-value" id="stat-chains">0</div>
                  <div class="ok-stat-label">{{ text_stat_chains }}</div>
                </div>
              </div>

            </div>

            {# ── Quick actions ── #}
            <div class="ok-panel">
              <div class="ok-panel-header">
                <span>{{ text_quick_actions }}</span>
              </div>
              <div class="ok-panel-body ok-quick-actions">
                <a href="{{ audit_url }}" class="ok-quick-action">
                  <i data-lucide="search"></i>
                  <span>{{ text_audit_run }}</span>
                </a>
                <a href="{{ meta_url }}" class="ok-quick-action">
                  <i data-lucide="tag"></i>
                  <span>{{ tab_meta }}</span>
                </a>
                <a href="{{ redirects_url }}" class="ok-quick-action">
                  <i data-lucide="arrow-right-left"></i>
                  <span>{{ tab_redirects }}</span>
                </a>
                <a href="{{ robots_url }}" class="ok-quick-action">
                  <i data-lucide="file-text"></i>
                  <span>{{ tab_robots }}</span>
                </a>
                <a href="{{ sitemap_url }}" class="ok-quick-action">
                  <i data-lucide="map"></i>
                  <span>{{ tab_sitemap }}</span>
                </a>
                <button type="button" id="ok-flatten-chains" class="ok-quick-action ok-quick-action-btn ok-hidden">
                  <i data-lucide="zap"></i>
                  <span>{{ button_flatten_chains }}</span>
                </button>
              </div>
            </div>

            {# ── Top-10 audit issues ── #}
            <div class="ok-panel" id="ok-audit-issues-panel">
              <div class="ok-panel-header">
                <span>{{ text_audit_issues_top }}</span>
                <small id="ok-audit-last-run" class="ok-hint"></small>
              </div>
              <table class="ok-table">
                <thead>
                  <tr>
                    <th class="ok-col-sm">{{ column_severity }}</th>
                    <th class="ok-col-sm">{{ column_type }}</th>
                    <th>{{ column_entity }}</th>
                    <th>{{ column_issue }}</th>
                  </tr>
                </thead>
                <tbody id="ok-audit-top-tbody">
                  <tr><td colspan="4" class="text-center ok-loading">{{ text_loading }}</td></tr>
                </tbody>
              </table>
              <div class="ok-panel-footer">
                <a href="{{ audit_url }}" class="ok-btn ok-btn-default ok-btn-sm">
                  <i data-lucide="list"></i> {{ text_all_audit_results }}
                </a>
              </div>
            </div>

            {# ── Top redirects ── #}
            <div class="ok-panel">
              <div class="ok-panel-header">
                <span>{{ text_top_redirects }}</span>
              </div>
              <table class="ok-table">
                <thead>
                  <tr>
                    <th>{{ column_from }}</th>
                    <th>{{ column_to }}</th>
                    <th class="ok-col-xs">{{ column_code }}</th>
                    <th class="ok-col-xs">{{ column_hits }}</th>
                  </tr>
                </thead>
                <tbody id="ok-top-redirects">
                  <tr><td colspan="4" class="text-center ok-loading">{{ text_loading }}</td></tr>
                </tbody>
              </table>
            </div>

            {# ── Chain warnings ── #}
            <div class="ok-panel ok-hidden" id="ok-chains-panel">
              <div class="ok-panel-header ok-panel-warning">
                <i data-lucide="alert-triangle"></i>
                <span>{{ text_chain_warning }}</span>
              </div>
              <div class="ok-panel-body" id="ok-chains-body"></div>
            </div>

          </div>{# /ok-content #}
        </div>{# /ok-layout #}
      </div>{# /ok-panel #}
    </div>{# /oc-kit #}
  </div>
</div>
{{ footer }}

<script>
window.seoCoreConfig = {
  dashboardStatsUrl: '{{ dashboard_stats_url }}',
  flattenChainsUrl:  '{{ flatten_chains_url }}',
  userToken:         '{{ user_token }}'
};
window.seoCoreI18n = {{ lang_js }};
lucide.createIcons();
</script>
