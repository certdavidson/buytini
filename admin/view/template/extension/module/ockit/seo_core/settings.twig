                  <div class="ok-modal-header">
                    <span class="ok-modal-title"><i data-lucide="route"></i> {{ text_route_meta_modal_title }}</span>
                    <button type="button" class="ok-modal-close" data-route-meta-close><i data-lucide="x"></i></button>
                  </div>
                  <div class="ok-modal-body">
                    <input type="hidden" id="ok-route-meta-id" value="">
                    <div class="ok-form-row">
                      <label class="ok-label form-label ok-label-required">{{ label_route }}</label>
                      <input type="text" id="ok-route-meta-route" class="ok-input ok-code-input"
                             placeholder="product/manufacturer">
                      <p class="ok-help">{{ text_route_meta_route_hint|raw }}</p>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label ok-label-required">{{ label_regen_lang }}</label>
                      <select id="ok-route-meta-lang" class="ok-select">
                        {% for lang in languages %}
                        <option value="{{ lang.language_id }}">{{ lang.name }}</option>
                        {% endfor %}
                      </select>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">Title</label>
                      <input type="text" id="ok-route-meta-title" class="ok-input" maxlength="255">
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">Description</label>
                      <textarea id="ok-route-meta-desc" class="ok-input" rows="3" maxlength="512"></textarea>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">Keywords</label>
                      <input type="text" id="ok-route-meta-keywords" class="ok-input" maxlength="255">
                    </div>
                    {% if supports_h1 %}
                    <div class="ok-form-row">
                      <label class="ok-label form-label">H1</label>
                      <input type="text" id="ok-route-meta-h1" class="ok-input" maxlength="255">
                    </div>
                    {% endif %}
                    <p class="ok-help">{{ text_route_meta_vars_hint|raw }}</p>
                  </div>
                  <div class="ok-modal-footer">
                    <button type="button" class="ok-btn ok-btn-default" data-route-meta-close>{{ button_cancel }}</button>
                    <button type="button" id="ok-route-meta-save" class="ok-btn ok-btn-primary">{{ button_save }}</button>
                  </div>
                </div>
              </div>
              <script>
              (function () {
                var i18n  = window.seoCoreI18n  || {};
                var token = (window.seoCoreConfig || {}).userToken || '';
                var listUrl   = '{{ route_meta_list_url }}';
                var saveUrl   = '{{ route_meta_save_url }}';
                var deleteUrl = '{{ route_meta_delete_url }}';
                var langMap   = {};
                {% for lang in languages %}
                  langMap[{{ lang.language_id }}] = '{{ lang.name|e('js') }}';
                {% endfor %}

                var tbody = document.getElementById('ok-route-meta-tbody');
                var modal = document.getElementById('ok-route-meta-modal');
                if (!tbody || !modal) return;
                var esc = window.okEsc || function (s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];}); };

                function load() {
                  var xhr = new XMLHttpRequest();
                  xhr.open('GET', listUrl, true);
                  xhr.onload = function () {
                    try {
                      var r = JSON.parse(xhr.responseText);
                      if (!r.success || !r.items.length) {
                        tbody.innerHTML = '<tr><td colspan="5" class="text-center ok-help">' + esc(i18n.text_no_data || 'No rows') + '</td></tr>';
                        return;
                      }
                      tbody.innerHTML = r.items.map(function (it) {
                        return '<tr>' +
                          '<td><code>' + esc(it.route) + '</code></td>' +
                          '<td>' + esc(langMap[it.language_id] || it.language_id) + '</td>' +
                          '<td>' + esc(it.title) + '</td>' +
                          '<td>' + esc((it.description || '').substring(0, 80)) + '</td>' +
                          '<td class="ok-col-actions">' +
                            '<button type="button" class="ok-btn ok-btn-sm ok-btn-default ok-route-meta-edit"' +
                              ' data-json="' + esc(JSON.stringify(it)) + '"><i data-lucide="edit-2"></i></button>' +
                            '<button type="button" class="ok-btn ok-btn-sm ok-btn-danger ok-route-meta-del"' +
                              ' data-id="' + it.route_meta_id + '"><i data-lucide="trash-2"></i></button>' +
                          '</td></tr>';
                      }).join('');
                      if (window.lucide) lucide.createIcons({ nodes: tbody.querySelectorAll('[data-lucide]') });
                    } catch(e) {}
                  };
                  xhr.send();
                }

                function openModal(row) {
                  document.getElementById('ok-route-meta-id').value       = row ? row.route_meta_id : '';
                  document.getElementById('ok-route-meta-route').value    = row ? row.route        : '';
                  document.getElementById('ok-route-meta-lang').value     = row ? row.language_id  : Object.keys(langMap)[0];
                  document.getElementById('ok-route-meta-title').value    = row ? row.title        : '';
                  document.getElementById('ok-route-meta-desc').value     = row ? row.description  : '';
                  document.getElementById('ok-route-meta-keywords').value = row ? row.keywords     : '';
                  var h1 = document.getElementById('ok-route-meta-h1');
                  if (h1) h1.value = row ? (row.h1 || '') : '';
                  modal.classList.remove('ok-hidden');
                  if (window.lucide) lucide.createIcons({ nodes: modal.querySelectorAll('[data-lucide]') });
                }
                function closeModal() { modal.classList.add('ok-hidden'); }

                document.getElementById('ok-route-meta-add').addEventListener('click', function () { openModal(null); });
                document.querySelectorAll('[data-route-meta-quick]').forEach(function (btn) {
                  btn.addEventListener('click', function () {
                    var preset = btn.getAttribute('data-route-meta-quick');
                    openModal(null);
                    document.getElementById('ok-route-meta-route').value = preset;
                  });
                });
                modal.querySelectorAll('[data-route-meta-close]').forEach(function (b) { b.addEventListener('click', closeModal); });

                document.getElementById('ok-route-meta-save').addEventListener('click', function () {
                  var data = new URLSearchParams({
                    route:       document.getElementById('ok-route-meta-route').value,
                    language_id: document.getElementById('ok-route-meta-lang').value,
                    title:       document.getElementById('ok-route-meta-title').value,
                    description: document.getElementById('ok-route-meta-desc').value,
                    keywords:    document.getElementById('ok-route-meta-keywords').value,
                    h1:          (document.getElementById('ok-route-meta-h1') || {value:''}).value,
                    user_token:  token
                  });
                  var xhr = new XMLHttpRequest();
                  xhr.open('POST', saveUrl, true);
                  xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                  xhr.onload = function () {
                    try {
                      var r = JSON.parse(xhr.responseText);
                      if (r.success) { closeModal(); load(); if (window.okNotify) okNotify(i18n.text_success || 'OK', 'success'); }
                      else if (window.okNotify) okNotify(r.message || 'Error', 'error');
                    } catch(e) {}
                  };
                  xhr.send(data.toString());
                });

                tbody.addEventListener('click', function (e) {
                  var edit = e.target.closest('.ok-route-meta-edit');
                  var del  = e.target.closest('.ok-route-meta-del');
                  if (edit) {
                    try { openModal(JSON.parse(edit.getAttribute('data-json'))); } catch (er) {}
                  } else if (del) {
                    if (!confirm(i18n.text_confirm_delete || 'Delete?')) return;
                    var data = new URLSearchParams({ route_meta_id: del.getAttribute('data-id'), user_token: token });
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', deleteUrl, true);
                    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
                    xhr.onload = function () { try { if (JSON.parse(xhr.responseText).success) load(); } catch(er){} };
                    xhr.send(data.toString());
                  }
                });

                document.addEventListener('click', function (e) {
                  if (e.target.closest('.ok-tabs-sidebar-item[data-tab="layout-meta"]')) load();
                });
                if (document.getElementById('layout-meta')) load();
              }());
              </script>

            </div>{# /layout-meta #}

