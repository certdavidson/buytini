                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ text_url_bulk_find }}</label>
                    <input type="text" id="ok-bulkrep-find" class="ok-input" placeholder="kupit-">
                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ text_url_bulk_replace_with }}</label>
                    <input type="text" id="ok-bulkrep-with" class="ok-input" placeholder="">
                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ text_url_bulk_regex }}</label>
                    <label class="ok-toggle-wrap">
                      <input type="checkbox" id="ok-bulkrep-regex" class="ok-toggle-input">
                      <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                    </label>
                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_regen_lang }}</label>
                    <select id="ok-bulkrep-lang" class="ok-select">
                      <option value="0">{{ text_all_langs }}</option>
                      {% for lang in languages %}
                      <option value="{{ lang.language_id }}">{{ lang.name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="ok-form-row">
                    <button type="button" id="ok-bulkrep-preview" class="ok-btn ok-btn-default" data-url="{{ url_bulk_replace_url }}">
                      <i data-lucide="eye"></i> {{ button_preview }}
                    </button>
                    <button type="button" id="ok-bulkrep-apply" class="ok-btn ok-btn-primary" data-url="{{ url_bulk_replace_url }}">
                      <i data-lucide="play"></i> {{ button_apply }}
                    </button>
                    <span id="ok-bulkrep-status" class="ok-help"></span>
                  </div>
                  <div id="ok-bulkrep-sample" class="ok-mt-2"></div>
                </div>
              </div>
              <script>
              (function () {
                var i18n   = window.seoCoreI18n || {};
                var status = document.getElementById('ok-bulkrep-status');
                var sample = document.getElementById('ok-bulkrep-sample');
                function run(btn, mode) {
                  var find    = document.getElementById('ok-bulkrep-find').value;
                  if (!find) return;
                  var fd = new FormData();
                  fd.append('find',    find);
                  fd.append('replace', document.getElementById('ok-bulkrep-with').value);
                  fd.append('regex',   document.getElementById('ok-bulkrep-regex').checked ? '1' : '0');
                  fd.append('language_id', document.getElementById('ok-bulkrep-lang').value);
                  fd.append('store_id', '0');
                  fd.append('mode', mode);
                  fd.append('user_token', (window.seoCoreConfig || {}).userToken || '');
                  status.textContent = (mode === 'preview' ? (i18n.js_running_preview || '…') : (i18n.js_running_apply || '…'));
                  btn.disabled = true;
                  var xhr = new XMLHttpRequest();
                  xhr.open('POST', btn.getAttribute('data-url'), true);
                  xhr.onload = function () {
                    btn.disabled = false;
                    try {
                      var r = JSON.parse(xhr.responseText);
                      if (!r.success) { status.textContent = r.error || (i18n.js_error || 'Error'); return; }
                      status.textContent = (mode === 'preview' ? (i18n.js_matched_preview || '') : (i18n.js_matched_apply || '')) + r.matched;
                      window.okNotify && okNotify(status.textContent, mode === 'preview' ? 'info' : 'success');
                      sample.innerHTML = (r.sample && r.sample.length)
                        ? '<table class="ok-table ok-table-compact"><thead><tr><th>old</th><th></th><th>new</th><th>query</th></tr></thead><tbody>' +
                          r.sample.map(function (c) {
                            return '<tr><td><code>' + esc(c.old) + '</code></td><td>→</td><td><code>' + esc(c.new) + '</code></td><td>' + esc(c.query) + '</td></tr>';
                          }).join('') + '</tbody></table>'
                        : '';
                    } catch (e) { status.textContent = (i18n.js_error || 'Error'); }
                  };
                  xhr.send(fd);
                }
                function esc(s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }
                document.getElementById('ok-bulkrep-preview').addEventListener('click', function () { run(this, 'preview'); });
                document.getElementById('ok-bulkrep-apply').addEventListener('click', function () {
                  if (confirm(i18n.js_confirm_bulk_apply || '?')) run(this, 'apply');
                });
              }());
              </script>

