{# SEO Core | © 2026 oc-kit.com | https://oc-kit.com #}
{{ header }}{{ column_left }}<div id="content">
  <div class="container-fluid">
    <div id="scf" class="oc-kit">
      <div class="ok-panel ok-panel-sticky">

        <div class="ok-panel-header">
          <ul class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
              <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
            {% endfor %}
          </ul>
          <div class="ok-panel-actions">
            {% if stores|length > 1 %}
            <select id="ok-store-selector" class="ok-select ok-select-sm" title="{{ title_store_selector }}">
              {% for s in stores %}
                <option value="{{ s.store_id }}">{{ s.name }}</option>
              {% endfor %}
            </select>
            {% endif %}
            <button type="button" id="ok-save-global" class="ok-btn ok-btn-primary ok-btn-sm">
              <i data-lucide="save"></i> {{ button_save }}
            </button>
            <a href="{{ cancel_url }}" class="ok-btn ok-btn-default ok-btn-sm">
              <i data-lucide="x"></i> {{ button_cancel }}
            </a>
          </div>
        </div>

        <div class="ok-layout">
          {% include 'extension/module/ockit/seo_core/_nav.twig' %}

          <div class="ok-content">

            {# ═══════════════════════════════════════════════════════ Dashboard ══ #}
            <div class="ok-layout-panel active" id="layout-dashboard">

              <div class="ok-kpi-grid ok-mb-4 ok-mt-0">
                <div class="ok-kpi-card ok-kpi-card--ok" title="{{ text_stat_seo_score_hint }}">
                  <div class="ok-kpi-card__icon"><i data-lucide="gauge"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-seo-score">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_seo_score }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--total">
                  <div class="ok-kpi-card__icon"><i data-lucide="link"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-seo-urls">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_seo_urls }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--info">
                  <div class="ok-kpi-card__icon"><i data-lucide="arrow-right-left"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-redirects">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_redirects }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--lost">
                  <div class="ok-kpi-card__icon"><i data-lucide="x"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-audit-errors">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_audit_errors }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--warning">
                  <div class="ok-kpi-card__icon"><i data-lucide="triangle-alert"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-audit-warnings">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_audit_warnings }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--ok">
                  <div class="ok-kpi-card__icon"><i data-lucide="mouse-pointer-click"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-redirect-hits">—</div>
                    <div class="ok-kpi-card__label">{{ text_stat_redirect_hits }}</div>
                  </div>
                </div>
                <div class="ok-kpi-card ok-kpi-card--warning ok-hidden" id="stat-chains-card">
                  <div class="ok-kpi-card__icon"><i data-lucide="alert-triangle"></i></div>
                  <div class="ok-kpi-card__body">
                    <div class="ok-kpi-card__value" id="stat-chains">0</div>
                    <div class="ok-kpi-card__label">{{ text_stat_chains }}</div>
                  </div>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <span>{{ text_quick_actions }}</span>
                </div>
                <div class="ok-panel-body ok-quick-actions">
                  <button type="button" class="ok-quick-action" data-switch-tab="layout-audit">
                    <i data-lucide="search"></i>
                    <span>{{ text_audit_run }}</span>
                  </button>
                  <button type="button" class="ok-quick-action" data-switch-tab="layout-meta">
                    <i data-lucide="tag"></i>
                    <span>{{ tab_meta }}</span>
                  </button>
                  <button type="button" class="ok-quick-action" data-switch-tab="layout-redirects">
                    <i data-lucide="arrow-right-left"></i>
                    <span>{{ tab_redirects }}</span>
                  </button>
                  <button type="button" class="ok-quick-action" data-switch-tab="layout-robots">
                    <i data-lucide="file-text"></i>
                    <span>{{ tab_robots }}</span>
                  </button>
                  <button type="button" class="ok-quick-action" data-switch-tab="layout-sitemap">
                    <i data-lucide="map"></i>
                    <span>{{ tab_sitemap }}</span>
                  </button>
                  <button type="button" id="ok-dash-warm-cache" class="ok-quick-action ok-quick-action-btn">
                    <i data-lucide="flame"></i>
                    <span>{{ button_warm_cache }}</span>
                  </button>
                  <button type="button" id="ok-flatten-chains" class="ok-quick-action ok-quick-action-btn ok-hidden">
                    <i data-lucide="zap"></i>
                    <span>{{ button_flatten_chains }}</span>
                  </button>
                </div>
              </div>

              <div class="ok-panel" id="ok-audit-issues-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="list-checks"></i> {{ text_audit_issues_top }}</h3>
                  <div class="ok-panel-actions">
                    <small id="ok-audit-last-run" class="ok-help"></small>
                  </div>
                </div>
                <table class="ok-table">
                  <thead>
                    <tr>
                      <th class="ok-col-sm">{{ column_severity }}</th>
                      <th class="ok-col-sm">{{ column_type }}</th>
                      <th class="ok-col-sm">ID</th>
                      <th>{{ column_entity }}</th>
                      <th>{{ column_issue }}</th>
                    </tr>
                  </thead>
                  <tbody id="ok-audit-top-tbody">
                    <tr><td colspan="5" class="text-center ok-loading">{{ text_loading }}</td></tr>
                  </tbody>
                </table>
                <div class="ok-panel-footer">
                  <button type="button" class="ok-btn ok-btn-outline-success ok-btn-sm" data-switch-tab="layout-audit">
                    <i data-lucide="list"></i> {{ text_all_audit_results }}
                  </button>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <span>{{ text_top_redirects }}</span>
                </div>
                <table class="ok-table">
                  <thead>
                    <tr>
                      <th>{{ column_from }}</th>
                      <th>{{ column_to }}</th>
                      <th class="ok-col-xs">{{ column_code }}</th>
                      <th class="ok-col-xs">{{ column_hits }}</th>
                    </tr>
                  </thead>
                  <tbody id="ok-top-redirects">
                    <tr><td colspan="4" class="text-center ok-loading">{{ text_loading }}</td></tr>
                  </tbody>
                </table>
              </div>

              <div class="ok-panel ok-hidden" id="ok-chains-panel">
                <div class="ok-panel-header ok-panel-warning">
                  <i data-lucide="alert-triangle"></i>
                  <span>{{ text_chain_warning }}</span>
                </div>
                <div class="ok-panel-body" id="ok-chains-body"></div>
              </div>

            </div>{# /layout-dashboard #}

            {# ═══════════════════════════════════════════════════════ Settings ══ #}
            <div class="ok-layout-panel" id="layout-settings">

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="settings-2"></i> {{ text_section_general }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_status }}</label>
                    <label class="ok-toggle-wrap">
                      <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_seo_core_status" value="1"
                        {% if module_oc_kit_seo_core_status %}checked{% endif %}>
                      <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                      <span class="ok-toggle-label">{{ text_enabled }}</span>
                    </label>
                  </div>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="link"></i> {{ text_section_url }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_url_depth }}</label>
                    <div class="ok-radio-grid">
                      {% set depth_cur = module_oc_kit_seo_core_url_depth == '' ? '0' : module_oc_kit_seo_core_url_depth %}
                      <label class="ok-radio-card {% if depth_cur == '0' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_url_depth" value="0" {% if depth_cur == '0' %}checked{% endif %}>
                        <span class="ok-radio-card-title">{{ text_depth_flat }}</span>
                        <code class="ok-radio-card-ex">{{ text_depth_flat_ex }}</code>
                      </label>
                      <label class="ok-radio-card {% if depth_cur == '1' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_url_depth" value="1" {% if depth_cur == '1' %}checked{% endif %}>
                        <span class="ok-radio-card-title">{{ text_depth_1 }}</span>
                        <code class="ok-radio-card-ex">{{ text_depth_1_ex }}</code>
                      </label>
                      <label class="ok-radio-card {% if depth_cur == '2' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_url_depth" value="2" {% if depth_cur == '2' %}checked{% endif %}>
                        <span class="ok-radio-card-title">{{ text_depth_2 }}</span>
                        <code class="ok-radio-card-ex">{{ text_depth_2_ex }}</code>
                      </label>
                      <label class="ok-radio-card {% if depth_cur == '-1' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_url_depth" value="-1" {% if depth_cur == '-1' %}checked{% endif %}>
                        <span class="ok-radio-card-title">{{ text_depth_full }}</span>
                        <code class="ok-radio-card-ex">{{ text_depth_full_ex }}</code>
                      </label>
                    </div>
                  </div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_product_include_category }}</label>
                    <div>
                      <div class="ok-radio-grid ok-radio-grid-2">
                        {% set pic_cur = module_oc_kit_seo_core_product_include_category ? '1' : '0' %}
                        <label class="ok-radio-card {% if pic_cur == '0' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_product_include_category" value="0" {% if pic_cur == '0' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ text_product_category_off }}</span>
                        </label>
                        <label class="ok-radio-card {% if pic_cur == '1' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_product_include_category" value="1" {% if pic_cur == '1' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ text_product_category_on }}</span>
                        </label>
                      </div>
                      <p class="ok-help">{{ text_product_category_hint }}</p>
                    </div>
                  </div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_trailing_slash }}</label>
                    <div>
                      {% set ts_cur = module_oc_kit_seo_core_trailing_slash %}
                      {% if ts_cur == '1' %}{% set ts_cur = 'all' %}{% endif %}
                      {% if ts_cur == '' or ts_cur == '0' %}{% set ts_cur = 'off' %}{% endif %}
                      <div class="ok-radio-grid ok-radio-grid-4">
                        <label class="ok-radio-card {% if ts_cur == 'off' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_trailing_slash" value="off" {% if ts_cur == 'off' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ label_trailing_slash_off }}</span>
                          <code class="ok-radio-card-ex">/page</code>
                        </label>
                        <label class="ok-radio-card {% if ts_cur == 'categories' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_trailing_slash" value="categories" {% if ts_cur == 'categories' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ label_trailing_slash_categories }}</span>
                          <code class="ok-radio-card-ex">/category/ + /product</code>
                        </label>
                        <label class="ok-radio-card {% if ts_cur == 'products' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_trailing_slash" value="products" {% if ts_cur == 'products' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ label_trailing_slash_products }}</span>
                          <code class="ok-radio-card-ex">/category + /product/</code>
                        </label>
                        <label class="ok-radio-card {% if ts_cur == 'all' %}active{% endif %}">
                          <input type="radio" name="module_oc_kit_seo_core_trailing_slash" value="all" {% if ts_cur == 'all' %}checked{% endif %}>
                          <span class="ok-radio-card-title">{{ label_trailing_slash_all }}</span>
                          <code class="ok-radio-card-ex">/page/</code>
                        </label>
                      </div>
                      <p class="ok-help">{{ text_trailing_slash_hint }}</p>
                    </div>
                  </div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_strip_query_params }}</label>
                    <div>
                      <textarea name="module_oc_kit_seo_core_strip_query_params" class="ok-input" rows="3"
                                placeholder="utm_*, gclid, fbclid, yclid, mc_eid, msclkid">{{ module_oc_kit_seo_core_strip_query_params }}</textarea>
                      <p class="ok-help">{{ text_strip_query_params_hint }}</p>
                    </div>
                  </div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_allow_duplicate_keywords }}</label>
                    <div>
                      <label class="ok-toggle-wrap">
                        <input type="checkbox" name="module_oc_kit_seo_core_allow_duplicate_keywords" value="1" class="ok-toggle-input"
                          {% if module_oc_kit_seo_core_allow_duplicate_keywords %}checked{% endif %}>
                        <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                      </label>
                      <p class="ok-help">{{ text_allow_duplicate_keywords_hint|raw }}</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="languages"></i> {{ text_section_lang_prefixes }}</h3>
                </div>
                <div class="ok-panel-body">
                  <input type="hidden" name="module_oc_kit_seo_core_lang_prefixes" id="ok-lang-prefixes-json" value="{{ module_oc_kit_seo_core_lang_prefixes|e('html_attr') }}">
                  <table class="ok-table ok-table-compact" id="ok-lang-prefixes-table">
                    <thead>
                      <tr>
                        <th>{{ label_regen_lang }}</th>
                        <th>{{ label_lang_prefixes }}</th>
                        <th class="ok-col-xs">{{ label_lang_default }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for lang in languages %}
                      <tr data-lang-id="{{ lang.language_id }}" data-lang-code="{{ lang.code }}">
                        <td>
                          <img src="language/{{ lang.code }}/{{ lang.code }}.png" title="{{ lang.name }}" class="ok-lang-flag">
                          {{ lang.name }}
                        </td>
                        <td><input type="text" class="ok-input ok-input-sm ok-lang-prefix" placeholder="" value=""></td>
                        <td>
                          <label class="ok-lang-default-radio">
                            <input type="radio" name="ok-lang-default" class="ok-lang-default" value="{{ lang.language_id }}">
                          </label>
                        </td>
                      </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                  <p class="ok-help">{{ text_lang_prefix_hint }}</p>
                </div>
              </div>

              <input type="hidden" name="module_oc_kit_seo_core_custom_routes" id="ok-custom-routes-json" value="{{ module_oc_kit_seo_core_custom_routes|e('html_attr') }}">

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="ban"></i> {{ text_section_skip_routes }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-alert ok-alert-warning nowrap"><i data-lucide="alert-triangle"></i> {{ text_skip_routes_why }}</div>
                  <table class="ok-table ok-table-compact" id="ok-skip-routes-table">
                    <thead>
                      <tr>
                        <th>{{ label_route_pattern }}</th>
                        <th class="ok-col-actions"></th>
                      </tr>
                    </thead>
                    <tbody id="ok-skip-routes-tbody"></tbody>
                  </table>
                </div>
                <div class="ok-panel-footer">
                  <button type="button" id="ok-skip-routes-add" class="ok-btn ok-btn-primary">
                    <i data-lucide="plus"></i> {{ button_add }}
                  </button>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="route"></i> {{ text_section_entity_routes }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-alert ok-alert-info nowrap"><i data-lucide="info"></i> {{ text_entity_routes_why }}</div>
                  <table class="ok-table ok-table-compact" id="ok-entity-routes-table">
                    <thead>
                      <tr>
                        <th>{{ label_entity_id }}</th>
                        <th>{{ label_route }}</th>
                        <th class="ok-col-actions"></th>
                      </tr>
                    </thead>
                    <tbody id="ok-entity-routes-tbody"></tbody>
                  </table>
                </div>
                <div class="ok-panel-footer">
                  <button type="button" id="ok-entity-routes-add" class="ok-btn ok-btn-primary">
                    <i data-lucide="plus"></i> {{ button_add }}
                  </button>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="list"></i> {{ text_section_pagination }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-alert ok-alert-info"><i data-lucide="info"></i> {{ text_pagination_intro }}</div>

                  <div class="ok-block-subtitle ok-mt-2"><i data-lucide="shield-x"></i> {{ text_pagination_invalid_title }}</div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_pagination_mode }}</label>
                    <div>
                      <select name="module_oc_kit_seo_core_pagination_mode" class="ok-select">
                        <option value="off" {% if module_oc_kit_seo_core_pagination_mode == 'off' or module_oc_kit_seo_core_pagination_mode == '' %}selected{% endif %}>{{ text_pagination_off }}</option>
                        <option value="404" {% if module_oc_kit_seo_core_pagination_mode == '404' %}selected{% endif %}>{{ text_pagination_404 }}</option>
                        <option value="redirect_last" {% if module_oc_kit_seo_core_pagination_mode == 'redirect_last' %}selected{% endif %}>{{ text_pagination_redirect_last }}</option>
                      </select>
                      <p class="ok-help">{{ text_pagination_mode_hint }}</p>
                    </div>
                  </div>

                  <div class="ok-block-subtitle ok-mt-3"><i data-lucide="eye-off"></i> {{ text_pagination_noindex_title }}</div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_noindex_all_pagination }}</label>
                    <label class="ok-toggle-wrap">
                      <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_seo_core_noindex_all_pagination" value="1"
                        {% if module_oc_kit_seo_core_noindex_all_pagination %}checked{% endif %}>
                      <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                    </label>
                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_noindex_delivery }}</label>
                    <div>
                      <select name="module_oc_kit_seo_core_noindex_delivery" class="ok-select">
                        {% set dlv = module_oc_kit_seo_core_noindex_delivery %}
                        <option value="meta"   {% if dlv == 'meta'   %}selected{% endif %}>{{ text_noindex_delivery_meta }}</option>
                        <option value="header" {% if dlv == 'header' %}selected{% endif %}>{{ text_noindex_delivery_header }}</option>
                        <option value="both"   {% if dlv == 'both'   %}selected{% endif %}>{{ text_noindex_delivery_both }}</option>
                      </select>
                      <p class="ok-help">{{ text_noindex_delivery_hint }}</p>
                    </div>
                  </div>
                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_noindex_from_page }}</label>
                    <div>
                      <input type="number" min="1" step="1" name="module_oc_kit_seo_core_noindex_from_page" class="ok-input ok-w-80"
                        value="{{ module_oc_kit_seo_core_noindex_from_page }}">
                      <p class="ok-help">{{ text_noindex_from_page_hint }}</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="database"></i> {{ text_section_cache }}</h3>
                  <div class="ok-panel-actions">
                    <span id="ok-cache-stats" class="ok-help">—</span>
                  </div>
                </div>
                <div class="ok-panel-body">
                  <p class="ok-help">{{ text_cache_hint }}</p>
                </div>
                <div class="ok-panel-footer">
                  <button type="button" id="ok-warm-cache" class="ok-btn ok-btn-primary">
                    <i data-lucide="flame"></i> {{ button_warm_cache }}
                  </button>
                  <button type="button" id="ok-clear-cache" class="ok-btn ok-btn-default">
                    <i data-lucide="trash-2"></i> {{ button_clear_cache }}
                  </button>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="zap"></i> {{ text_section_resource_hints }}</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-alert ok-alert-info">
                    <i data-lucide="info"></i>
                    {{ text_resource_hints_about|raw }}
                  </div>
                  <input type="hidden" name="module_oc_kit_seo_core_resource_hints" id="ok-hints-json" value="{{ module_oc_kit_seo_core_resource_hints|e('html_attr') }}">
                  <table class="ok-table ok-table-compact" id="ok-hints-table">
                    <thead>
                      <tr>
                        <th class="ok-col-sm">rel</th>
                        <th>href</th>
                        <th class="ok-col-sm">as</th>
                        <th class="ok-col-sm">type</th>
                        <th class="ok-col-xs">crossorigin</th>
                        <th class="ok-col-actions"></th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
