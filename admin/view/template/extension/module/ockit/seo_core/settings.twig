                  <div class="ok-form-row">
                    <button type="button" id="ok-broken-scan" class="ok-btn ok-btn-primary" data-url="{{ broken_links_scan_url }}">
                      <i data-lucide="scan-search"></i> {{ button_scan }}
                    </button>
                    <button type="button" id="ok-broken-refresh" class="ok-btn ok-btn-default" data-url="{{ broken_links_list_url }}">
                      <i data-lucide="refresh-cw"></i> {{ button_refresh }}
                    </button>
                    <span id="ok-broken-status" class="ok-help"></span>
                  </div>
                  <table class="ok-table ok-table-compact">
                    <thead>
                      <tr>
                        <th>URL</th>
                        <th class="ok-col-sm">{{ column_status }}</th>
                        <th>{{ column_entity }}</th>
                        <th class="ok-col-sm">{{ column_date }}</th>
                      </tr>
                    </thead>
                    <tbody id="ok-broken-tbody">
                      <tr><td colspan="4" class="text-center ok-muted">{{ text_no_data }}</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
              <script>
              (function () {
                var i18n = window.seoCoreI18n || {};
                var status = document.getElementById('ok-broken-status');
                var tbody  = document.getElementById('ok-broken-tbody');
                var token  = (window.seoCoreConfig || {}).userToken || '';

                function escapeHtml(s) {
                  return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
                    return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;' }[c];
                  });
                }
                function renderRows(items) {
                  if (!items.length) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center ok-muted">Битих посилань не знайдено</td></tr>';
                    return;
                  }
                  tbody.innerHTML = items.map(function (r) {
                    var badgeCls = r.status_code >= 500 ? 'ok-badge-error'
                                : r.status_code >= 400 ? 'ok-badge-warning'
                                : 'ok-badge-muted';
                    var statusTxt = r.status_code ? r.status_code : (r.error || 'timeout');
                    return '<tr>'
                      + '<td><code class="ok-text-sm">' + escapeHtml(r.url) + '</code></td>'
                      + '<td><span class="ok-badge ' + badgeCls + '">' + escapeHtml(statusTxt) + '</span></td>'
                      + '<td>' + escapeHtml(r.entity_type) + ' #' + r.entity_id + '<br><span class="ok-text-sm ok-muted">' + escapeHtml(r.entity_name) + '</span></td>'
                      + '<td>' + escapeHtml(r.checked_at) + '</td>'
                      + '</tr>';
                  }).join('');
                }
                function refresh() {
                  var btn = document.getElementById('ok-broken-refresh');
                  status.textContent = (i18n.js_loading || "Loading…");
                  var xhr = new XMLHttpRequest();
                  xhr.open('GET', btn.getAttribute('data-url'), true);
                  xhr.onload = function () {
                    try {
                      var r = JSON.parse(xhr.responseText);
                      renderRows(r.items || []);
                      status.textContent = (i18n.js_records_label || "Records: ") + (r.total || 0);
                    } catch (e) { status.textContent = (i18n.js_error || 'Error'); }
                  };
                  xhr.send();
                }

                var scan = document.getElementById('ok-broken-scan');
                if (scan) scan.addEventListener('click', function () {
                  if (!confirm('Це може зайняти 1-3 хвилини в залежності від кількості посилань. Продовжити?')) return;
                  status.textContent = 'Сканую…';
                  scan.disabled = true;
                  var fd = new FormData();
                  fd.append('user_token', token);
                  var xhr = new XMLHttpRequest();
                  xhr.open('POST', scan.getAttribute('data-url'), true);
                  xhr.onload = function () {
                    scan.disabled = false;
                    try {
                      var r = JSON.parse(xhr.responseText);
                      status.textContent = 'Перевірено ' + (r.checked || 0) + ', знайдено битих ' + (r.broken || 0);
                      window.okNotify && okNotify(status.textContent, (r.broken || 0) > 0 ? 'warning' : 'success');
                      refresh();
                    } catch (e) { status.textContent = (i18n.js_error || 'Error'); }
                  };
                  xhr.send(fd);
                });
                var rb = document.getElementById('ok-broken-refresh');
                if (rb) rb.addEventListener('click', refresh);
              }());
              </script>

