            {# ══════════════════════════════════════════════════ Robots.txt ══ #}
            <div class="ok-layout-panel" id="layout-robots">

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="file-text"></i> {{ text_robots_editor }}</h3>
                  <div class="ok-panel-actions">
                    <span class="ok-help">{{ robots_path }}</span>
                  </div>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-mb-2 ok-flex ok-gap-1">
                    <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-robots-quick="block-index"
                            title="Disallow: /index.php?route=*">
                      <i data-lucide="shield"></i> {{ text_robots_quick_block_index }}
                    </button>
                    <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-robots-quick="add-sitemap"
                            title="Sitemap: {{ config_url }}/sitemap.xml">
                      <i data-lucide="map"></i> {{ text_robots_quick_sitemap }}
                    </button>
                    <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-robots-quick="default-template"
                            title="Стандартний шаблон robots.txt для OpenCart">
                      <i data-lucide="file-plus"></i> {{ text_robots_quick_default }}
                    </button>
                  </div>
                  <div class="ok-robots-wrap">
                    <pre id="ok-robots-highlight" class="ok-robots-highlight" aria-hidden="true"></pre>
                    <textarea id="ok-robots-content" class="ok-input ok-robots-textarea" rows="20" spellcheck="false">{{ robots_content }}</textarea>
                  </div>
                  <span id="ok-robots-errors" class="ok-text-error ok-hidden ok-mt-2"></span>
                </div>
                <div class="ok-panel-footer">
                  <button type="button" id="ok-robots-save" class="ok-btn ok-btn-primary">
                    <i data-lucide="save"></i> {{ button_save }}
                  </button>
                </div>
              </div>
              <script>
              (function () {
                var ta = document.getElementById('ok-robots-content'); if (!ta) return;
                var hi = document.getElementById('ok-robots-highlight');

                var DIRECTIVES = /^(User-agent|Disallow|Allow|Sitemap|Host|Crawl-delay|Clean-param|Noindex):/i;
                function escHtml(s) { return s.replace(/[&<>]/g, function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;'}[c];}); }
                function highlight() {
                  if (!hi) return;
                  var lines = ta.value.split('\n').map(function (line) {
                    var trimmed = line.trimStart();
                    if (trimmed === '') return '';
                    if (trimmed[0] === '#') return '<span class="tok-comment">' + escHtml(line) + '</span>';
                    var m = line.match(/^(\s*)([A-Za-z-]+)(\s*:\s*)(.*)$/);
                    if (!m || !DIRECTIVES.test(m[2] + ':')) return escHtml(line);
                    var directive = m[2];
                    var rest = m[4];
                    var restHtml;
                    if (/^https?:\/\//i.test(rest)) {
                      restHtml = '<span class="tok-url">' + escHtml(rest) + '</span>';
                    } else {
                      // path: highlight glob chars
                      restHtml = escHtml(rest).replace(/(\*|\$)/g, '<span class="tok-glob">$1</span>');
                      if (rest !== '') restHtml = '<span class="tok-path">' + restHtml + '</span>';
                    }
                    return m[1]
                      + '<span class="tok-directive">' + escHtml(directive) + '</span>'
                      + escHtml(m[3])
                      + restHtml;
                  });
                  // trailing newline so the <pre> matches textarea height
                  hi.innerHTML = lines.join('\n') + '\n';
                }
                function syncScroll() {
                  if (!hi) return;
                  hi.scrollTop  = ta.scrollTop;
                  hi.scrollLeft = ta.scrollLeft;
                }
                ta.addEventListener('input',  function () { highlight(); syncScroll(); });
                ta.addEventListener('scroll', syncScroll);
                highlight();

                document.querySelectorAll('[data-robots-quick]').forEach(function (btn) {
                  btn.addEventListener('click', function () {
                    var v = ta.value;
                    var append = function (line) {
                      if (v.indexOf(line) !== -1) return;
                      ta.value = v.replace(/\s*$/, '') + '\n' + line + '\n';
                    };
                    var kind = btn.getAttribute('data-robots-quick');
                    if (kind === 'block-index')      append('Disallow: /index.php?route=*');
                    if (kind === 'add-sitemap')      append('Sitemap: {{ config_url }}/sitemap.xml');
                    if (kind === 'default-template') {
                      if (ta.value.trim() === '') {
                        ta.value = "User-agent: *\nDisallow: /admin\nDisallow: /system\nDisallow: /cache\nDisallow: /catalog/view/javascript\nDisallow: /catalog/view/theme\nDisallow: /index.php?route=account\nDisallow: /index.php?route=checkout\nDisallow: /*?filter_*\nDisallow: /*?sort=*\nDisallow: /*?order=*\nDisallow: /*&filter_*\nDisallow: /*&sort=*\n\nSitemap: {{ config_url }}/sitemap.xml\n";
                      }
                    }
                    highlight();
                  });
                });
              }());
              </script>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <span>{{ text_robots_backups }}</span>
                </div>
                <table class="ok-table" id="ok-robots-backups-table">
                  <thead>
                    <tr>
                      <th>{{ column_file }}</th>
                      <th class="ok-col-sm">{{ column_size }}</th>
                      <th class="ok-col-sm">{{ column_date }}</th>
                      <th class="ok-col-actions"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% if robots_backups %}
