                        <td>{{ bk.filename }}</td>
                        <td>{{ bk.size }} bytes</td>
                        <td>{{ bk.date }}</td>
                        <td class="ok-col-actions">
                          <button type="button" class="ok-btn ok-btn-sm ok-btn-default ok-robots-diff" title="{{ button_diff }}">
                            <i data-lucide="file-diff"></i> {{ button_diff }}
                          </button>
                          <button type="button" class="ok-btn ok-btn-sm ok-btn-default ok-robots-restore">
                            <i data-lucide="rotate-ccw"></i> {{ button_restore }}
                          </button>
                        </td>
                      </tr>
                      {% endfor %}
                    {% else %}
                      <tr><td colspan="4" class="text-center ok-muted">{{ text_no_backups }}</td></tr>
                    {% endif %}
                  </tbody>
                </table>
              </div>

            </div>{# /layout-robots #}

