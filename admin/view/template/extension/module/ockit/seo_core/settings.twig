            {# ════════════════════════════════════════════════════ Hreflang ══ #}
            <div class="ok-layout-panel" id="layout-hreflang">

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="languages"></i> Hreflang</h3>
                </div>
                <div class="ok-panel-body">
                  <div class="ok-alert ok-alert-info"><i data-lucide="info"></i> {{ text_hreflang_about }}</div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_hreflang_enabled }}</label>
                    <label class="ok-toggle-wrap">
                      <input type="checkbox" name="module_oc_kit_seo_core_hreflang_enabled" value="1" class="ok-toggle-input" {% if hreflang_settings.enabled %}checked{% endif %}>
                      <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                    </label>
                  </div>

                  <div class="ok-form-row">
                    <label class="ok-label form-label">{{ label_hreflang_format }}</label>
                    <div class="ok-radio-grid ok-radio-grid-2">
                      {% set hf = hreflang_settings.format %}
                      <label class="ok-radio-card {% if hf == 'iso' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_hreflang_format" value="iso" {% if hf == 'iso' %}checked{% endif %}>
                        <span class="ok-radio-card-title">ISO 639-1 (uk, ru, en)</span>
                        <code class="ok-radio-card-ex">hreflang="uk"</code>
                      </label>
                      <label class="ok-radio-card {% if hf == 'bcp47' %}active{% endif %}">
                        <input type="radio" name="module_oc_kit_seo_core_hreflang_format" value="bcp47" {% if hf == 'bcp47' %}checked{% endif %}>
                        <span class="ok-radio-card-title">BCP 47 (uk-UA, ru-UA)</span>
                        <code class="ok-radio-card-ex">hreflang="uk-UA"</code>
                      </label>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ok-panel">
                <div class="ok-panel-header">
                  <h3 class="ok-panel-title"><i data-lucide="eye"></i> {{ text_hreflang_preview }}</h3>
                </div>
                <table class="ok-table">
                  <thead>
                    <tr>
                      <th>{{ label_regen_lang }}</th>
                      <th class="ok-col-sm">Code</th>
                      <th class="ok-col-sm">Prefix</th>
                      <th class="ok-col-sm">hreflang</th>
                      <th class="ok-col-sm">x-default</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for lang in languages %}
                    {% set short = lang.code|split('-')|first %}
                    <tr>
                      <td>
                        <img src="language/{{ lang.code }}/{{ lang.code }}.png" title="{{ lang.name }}" class="ok-lang-flag">
                        {{ lang.name }}
                      </td>
                      <td><code>{{ lang.code }}</code></td>
                      <td><code>{% if loop.first %}— (default){% else %}{{ short }}{% endif %}</code></td>
                      <td>
                        {% if hreflang_settings.format == 'bcp47' %}
                          <code class="ok-badge ok-badge-info-soft">{{ lang.code }}</code>
                        {% else %}
                          <code class="ok-badge ok-badge-info-soft">{{ short }}</code>
                        {% endif %}
                      </td>
                      <td>{% if loop.first %}<span class="ok-badge ok-badge-success ok-badge-squared">✓</span>{% endif %}</td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>

            </div>{# /layout-hreflang #}

