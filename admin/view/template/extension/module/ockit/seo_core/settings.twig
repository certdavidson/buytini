                  <div class="ok-form-row">
                    <button type="button" id="ok-img-alt-preview" class="ok-btn ok-btn-default" data-url="{{ image_alt_bulk_fill_url }}">
                      <i data-lucide="eye"></i> {{ button_preview }}
                    </button>
                    <button type="button" id="ok-img-alt-apply" class="ok-btn ok-btn-primary" data-url="{{ image_alt_bulk_fill_url }}">
                      <i data-lucide="play"></i> {{ button_apply }}
                    </button>
                    <span id="ok-img-alt-status" class="ok-help"></span>
                  </div>
                </div>
              </div>
              <script>
              (function () {
                var i18n = window.seoCoreI18n || {};
                var status = document.getElementById('ok-img-alt-status');
                function run(btn, mode) {
                  var url = btn.getAttribute('data-url');
                  var token = (window.seoCoreConfig || {}).userToken || '';
                  var langSel = document.getElementById('ok-img-alt-lang');
                  if (!langSel || !url) { status.textContent = (i18n.js_url_not_set || "URL not set"); return; }
                  var fd = new FormData();
                  fd.append('language_id', langSel.value);
                  fd.append('mode', mode);
                  fd.append('user_token', token);
                  status.textContent = (i18n.js_running || "Running…");
                  var xhr = new XMLHttpRequest();
                  xhr.open('POST', url, true);
                  xhr.onload = function () {
                    try {
                      var r = JSON.parse(xhr.responseText);
                      status.textContent = (mode === 'preview' ? (i18n.js_preview_label || "Preview: ") : (i18n.js_done_label || "Done: "))
                        + (i18n.js_products_label || "products ") + (r.touched || 0) + (i18n.js_alts_added || ", alts added ") + (r.alts_added || 0);
                      window.okNotify && okNotify(status.textContent, mode === 'preview' ? 'info' : 'success');
                    } catch (e) { status.textContent = (i18n.js_error || 'Error'); }
                  };
                  xhr.send(fd);
                }
                var p = document.getElementById('ok-img-alt-preview');
                var a = document.getElementById('ok-img-alt-apply');
                if (p) p.addEventListener('click', function () { run(p, 'preview'); });
                if (a) a.addEventListener('click', function () {
                  if (confirm((i18n.js_confirm_img_alt || "Run bulk alt fill?"))) run(a, 'apply');
                });
              }());
              </script>

