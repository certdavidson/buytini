    group.querySelectorAll('.ok-lang-tab-btn').forEach(function (b) { b.classList.toggle('active', b === btn); });
    group.querySelectorAll('.ok-lang-tab-panel').forEach(function (p) {
      p.classList.toggle('ok-hidden', p.getAttribute('data-lang-panel') !== key);
    });
  });
}());

// ── Google Search Console ────────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var redirectInput = document.getElementById('ok-gsc-redirect-uri');
  var connectBtn    = document.getElementById('ok-gsc-connect-btn');
  var disconnectBtn = document.getElementById('ok-gsc-disconnect-btn');
  var statusBadge   = document.getElementById('ok-gsc-status-badge');
  if (!redirectInput) return;

  var esc = window.okEsc || function (s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  }); };

  function loadStatus() {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', cfg.gscStatusUrl, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (!res.success) return;
        redirectInput.value = res.redirect_uri || '';
        if (connectBtn) connectBtn.href = cfg.gscConnectUrl;
        if (res.connected) {
          statusBadge.textContent = i18n.text_gsc_connected || 'Connected';
          statusBadge.className   = 'ok-badge ok-badge-success';
          if (connectBtn)    connectBtn.style.display    = 'none';
          if (disconnectBtn) disconnectBtn.style.display = '';
          loadSitemaps();
        } else {
          statusBadge.textContent = i18n.text_gsc_disconnected || 'Not connected';
          statusBadge.className   = 'ok-badge ok-badge-default';
          if (connectBtn)    connectBtn.style.display    = '';
          if (disconnectBtn) disconnectBtn.style.display = 'none';
        }
      } catch(e) {}
    };
    xhr.send();
  }

  if (disconnectBtn) disconnectBtn.addEventListener('click', function () {
    if (!confirm(i18n.text_gsc_confirm_disconnect || 'Disconnect Google?')) return;
    var data = new URLSearchParams({ user_token: cfg.userToken });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', cfg.gscDisconnectUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () { try { if (JSON.parse(xhr.responseText).success) loadStatus(); } catch(e){} };
    xhr.send(data.toString());
  });

  // Stats
  var statsBtn = document.getElementById('ok-gsc-stats-load');
  var statsTb  = document.getElementById('ok-gsc-stats-tbody');
  var dimSel   = document.getElementById('ok-gsc-dim');
  if (statsBtn) statsBtn.addEventListener('click', function () {
    var url = cfg.gscStatsUrl + '&dimension=' + encodeURIComponent(dimSel.value);
    var xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    statsTb.innerHTML = '<tr><td colspan="5" class="text-center ok-loading">' + esc(i18n.text_loading || (i18n.js_loading || "Loading…")) + '</td></tr>';
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (!res.success) {
          statsTb.innerHTML = '<tr><td colspan="5" class="text-center"><span class="ok-text-error">' + esc(res.message || 'Error') + '</span></td></tr>';
          return;
        }
        var rows = (res.data && res.data.rows) || [];
        if (!rows.length) {
          statsTb.innerHTML = '<tr><td colspan="5" class="text-center ok-help">' + esc(i18n.text_no_data || 'Немає даних') + '</td></tr>';
          return;
        }
        statsTb.innerHTML = rows.map(function (r) {
          var key = (r.keys && r.keys[0]) || '';
          var ctr = ((r.ctr || 0) * 100).toFixed(2) + '%';
          var pos = (r.position || 0).toFixed(1);
          return '<tr><td>' + esc(key) + '</td><td>' + esc(r.clicks) + '</td><td>' + esc(r.impressions) + '</td><td>' + ctr + '</td><td>' + pos + '</td></tr>';
        }).join('');
      } catch(e) {
        statsTb.innerHTML = '<tr><td colspan="5" class="text-center"><span class="ok-text-error">Parse error</span></td></tr>';
      }
    };
    xhr.send();
  });

  // Sitemaps
  var smTb = document.getElementById('ok-gsc-sitemaps-tbody');
  function loadSitemaps() {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', cfg.gscSitemapListUrl, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (!res.success) {
          smTb.innerHTML = '<tr><td colspan="5" class="text-center"><span class="ok-text-error">' + esc(res.message || 'Error') + '</span></td></tr>';
          return;
        }
        var rows = (res.data && res.data.sitemap) || [];
        if (!rows.length) {
          smTb.innerHTML = '<tr><td colspan="5" class="text-center ok-help">' + esc(i18n.text_no_data || 'Немає sitemap-ів') + '</td></tr>';
          return;
        }
        smTb.innerHTML = rows.map(function (s) {
          return '<tr data-path="' + esc(s.path) + '">'
            + '<td>' + esc(s.path) + '</td>'
            + '<td>' + esc(s.lastSubmitted || '') + '</td>'
            + '<td>' + esc(s.errors || 0) + '</td>'
            + '<td>' + esc(s.warnings || 0) + '</td>'
            + '<td class="ok-col-actions"><button type="button" class="ok-btn ok-btn-sm ok-btn-danger ok-gsc-sitemap-del" title="Delete"><i data-lucide="trash-2"></i></button></td>'
            + '</tr>';
        }).join('');
        if (window.lucide) lucide.createIcons({ nodes: smTb.querySelectorAll('[data-lucide]') });
      } catch(e) {}
    };
    xhr.send();
  }

  var smSubmitBtn  = document.getElementById('ok-gsc-sitemap-submit');
  var smRefreshBtn = document.getElementById('ok-gsc-sitemap-refresh');
  var smInput      = document.getElementById('ok-gsc-sitemap-url');
  if (smSubmitBtn) smSubmitBtn.addEventListener('click', function () {
    if (!smInput.value) return;
    postGsc(cfg.gscSitemapSubmitUrl, { url: smInput.value }, function () { loadSitemaps(); smInput.value = ''; });
  });
  if (smRefreshBtn) smRefreshBtn.addEventListener('click', loadSitemaps);
  if (smTb) smTb.addEventListener('click', function (e) {
    var del = e.target.closest('.ok-gsc-sitemap-del');
    if (!del) return;
    var path = del.closest('tr').getAttribute('data-path');
    if (!confirm(i18n.text_confirm_delete || 'Delete?')) return;
    postGsc(cfg.gscSitemapDeleteUrl, { url: path }, loadSitemaps);
  });

  function postGsc(url, payload, onSuccess) {
    payload.user_token = cfg.userToken;
    var data = new URLSearchParams(payload);
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.success) {
          if (window.okNotify) okNotify(i18n.text_success || 'OK', 'success');
          if (onSuccess) onSuccess(res);
        } else if (window.okNotify) okNotify(res.message || 'Error', 'error');
      } catch(e) {}
    };
    xhr.send(data.toString());
  }

  loadStatus();
}());

// ── A/B title test ────────────────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var tbody = document.getElementById('ok-ab-tbody');
  if (!tbody) return;

  var modal = document.getElementById('ok-ab-modal');
  var addBtn = document.getElementById('ok-ab-add');
  var saveBtn = document.getElementById('ok-ab-save');
  var esc = window.okEsc || function (s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  }); };

  function load() {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', cfg.abTestListUrl, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (!res.success) return;
        if (!res.tests.length) {
          tbody.innerHTML = '<tr><td colspan="9" class="text-center ok-help">' + esc(i18n.text_no_data || 'Немає тестів') + '</td></tr>';
          return;
        }
        tbody.innerHTML = res.tests.map(function (t) {
          var langName = (cfg.langMap || {})[t.language_id] || t.language_id;
          var statusBadge = t.status === 'active'
            ? '<span class="ok-badge ok-badge-success">active</span>'
            : '<span class="ok-badge ok-badge-default">ended</span>';
          var endBtn = t.status === 'active'
            ? '<button class="ok-btn ok-btn-sm ok-btn-warning ok-ab-end" data-id="' + t.test_id + '" title="End"><i data-lucide="square"></i></button>'
            : '';
          return '<tr>'
            + '<td>' + esc(t.entity_type) + '</td>'
            + '<td>' + esc(t.entity_id) + '</td>'
            + '<td>' + esc(langName) + '</td>'
            + '<td>' + esc(t.variant_a_title) + '</td>'
            + '<td>' + esc(t.variant_b_title) + '</td>'
            + '<td>' + esc(t.hits_a) + '</td>'
            + '<td>' + esc(t.hits_b) + '</td>'
            + '<td>' + statusBadge + '</td>'
            + '<td class="ok-col-actions">' + endBtn
            + ' <button class="ok-btn ok-btn-sm ok-btn-danger ok-ab-del" data-id="' + t.test_id + '" title="Delete"><i data-lucide="trash-2"></i></button></td>'
            + '</tr>';
        }).join('');
        if (window.lucide) lucide.createIcons({ nodes: tbody.querySelectorAll('[data-lucide]') });
      } catch(e) {}
    };
    xhr.send();
  }

  function openModal() {
    document.getElementById('ok-ab-entity-id').value = '';
    document.getElementById('ok-ab-title-a').value = '';
    document.getElementById('ok-ab-title-b').value = '';
    modal.style.display = 'flex';
  }
  function closeModal() { modal.style.display = 'none'; }

  if (addBtn) addBtn.addEventListener('click', openModal);
  modal.querySelectorAll('[data-ab-close]').forEach(function (b) { b.addEventListener('click', closeModal); });

  if (saveBtn) saveBtn.addEventListener('click', function () {
    var data = new URLSearchParams({
      entity_type: document.getElementById('ok-ab-type').value,
      entity_id:   document.getElementById('ok-ab-entity-id').value,
      language_id: document.getElementById('ok-ab-lang').value,
      title_a:     document.getElementById('ok-ab-title-a').value,
      title_b:     document.getElementById('ok-ab-title-b').value,
      user_token:  cfg.userToken
    });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', cfg.abTestSaveUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.success) { closeModal(); load(); if (window.okNotify) okNotify('Saved', 'success'); }
        else if (window.okNotify) okNotify(res.message || 'Error', 'error');
      } catch(e) {}
    };
    xhr.send(data.toString());
  });

  tbody.addEventListener('click', function (e) {
    var endBtn = e.target.closest('.ok-ab-end');
    var delBtn = e.target.closest('.ok-ab-del');
    if (endBtn) {
      if (!confirm(i18n.text_confirm_end || 'End this test?')) return;
      postAndReload(cfg.abTestEndUrl, { test_id: endBtn.getAttribute('data-id') });
    } else if (delBtn) {
      if (!confirm(i18n.text_confirm_delete || 'Delete this test?')) return;
      postAndReload(cfg.abTestDeleteUrl, { test_id: delBtn.getAttribute('data-id') });
    }
  });

  function postAndReload(url, payload) {
    payload.user_token = cfg.userToken;
    var data = new URLSearchParams(payload);
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () { try { if (JSON.parse(xhr.responseText).success) load(); } catch(e){} };
    xhr.send(data.toString());
  }

  // Lazy-load when Meta tab opens
  document.addEventListener('click', function (e) {
    if (e.target.closest('.ok-tabs-sidebar-item[data-tab="layout-meta"]')) load();
  });
  // Initial load if already on meta tab
  if (document.querySelector('#layout-meta.active') || document.getElementById('layout-meta')) load();
}());

lucide.createIcons();
</script>
