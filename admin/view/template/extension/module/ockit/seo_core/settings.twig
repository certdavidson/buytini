              <script>
              (function () {
                var hidden = document.getElementById('ok-hints-json');
                var tbody  = document.querySelector('#ok-hints-table tbody');
                if (!hidden || !tbody) return;

                function parse() {
                  try { var v = hidden.value; if (!v) return []; v = v.replace(/&quot;/g, '"'); return JSON.parse(v) || []; } catch (e) { return []; }
                }
                function serialize() {
                  var rows = tbody.querySelectorAll('tr');
                  var out = [];
                  rows.forEach(function (tr) {
                    var inputs = tr.querySelectorAll('input');
                    var rel = inputs[0].value.trim();
                    var href = inputs[1].value.trim();
                    if (!rel || !href) return;
                    var hint = { rel: rel, href: href };
                    if (inputs[2].value.trim()) hint.as = inputs[2].value.trim();
                    if (inputs[3].value.trim()) hint.type = inputs[3].value.trim();
                    if (inputs[4].value.trim()) hint.crossorigin = inputs[4].value.trim();
                    out.push(hint);
                  });
                  hidden.value = JSON.stringify(out);
                }
                function row(h) {
                  h = h || {};
                  var tr = document.createElement('tr');
                  tr.innerHTML =
                    '<td><input type="text" class="ok-input ok-input-sm" placeholder="dns-prefetch" value="' + (h.rel || '') + '"></td>' +
                    '<td><input type="text" class="ok-input ok-input-sm" placeholder="//example.com" value="' + (h.href || '') + '"></td>' +
                    '<td><input type="text" class="ok-input ok-input-sm" placeholder="font" value="' + (h.as || '') + '"></td>' +
                    '<td><input type="text" class="ok-input ok-input-sm" placeholder="font/woff2" value="' + (h.type || '') + '"></td>' +
                    '<td><input type="text" class="ok-input ok-input-sm" placeholder="anonymous" value="' + (h.crossorigin || '') + '"></td>' +
                    '<td class="ok-col-actions"><button type="button" class="ok-btn ok-btn-sm ok-btn-danger ok-hint-rm"><i data-lucide="trash-2"></i></button></td>';
                  tbody.appendChild(tr);
                  if (typeof lucide !== 'undefined') lucide.createIcons();
                }

                parse().forEach(row);

                document.getElementById('ok-hints-add').addEventListener('click', function () { row(); });
                tbody.addEventListener('click', function (e) {
                  var rm = e.target.closest('.ok-hint-rm');
                  if (rm) { rm.closest('tr').remove(); serialize(); }
                });
                tbody.addEventListener('input', serialize);
              }());
              </script>

