// ── Redirects: stale delete ───────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var btn  = document.getElementById('ok-redirect-delete-stale');
  if (!btn) return;
  btn.addEventListener('click', function () {
    var days = prompt(i18n.redirects_stale_days_prompt || 'Delete 0-hit redirects older than N days:', '90');
    if (!days || !/^\d+$/.test(days)) return;
    if (!confirm((i18n.confirm_delete_stale || 'Delete all 0-hit redirects older than') + ' ' + days + ' ' + (i18n.days || 'days') + '?')) return;
    var data = new URLSearchParams({ days: days, user_token: cfg.userToken });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', cfg.redirectsDeleteStaleUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.success) {
          window.okNotify && okNotify((i18n.deleted || 'Deleted') + ': ' + (res.deleted || 0), 'success');
          if (window.loadRedirects) window.loadRedirects(1);
        }
      } catch(e) {}
    };
    xhr.send(data.toString());
  });
}());

// ── Cache management ──────────────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var warmBtn  = document.getElementById('ok-warm-cache');
  var clearBtn = document.getElementById('ok-clear-cache');
  var statsEl  = document.getElementById('ok-cache-stats');
  if (!warmBtn && !clearBtn) return;

  function loadStats() {
    if (!statsEl || !cfg.cacheStatsUrl) return;
    var xhr = new XMLHttpRequest();
    xhr.open('GET', cfg.cacheStatsUrl, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        var warm = res.warm ? '✓ ' + (i18n.cache_warm || 'warm') : '✗ ' + (i18n.cache_cold || 'cold');
        var info = warm + ' · ' + (res.entries || 0) + ' ' + (i18n.cache_entries || 'entries');
        if (res.size_kb) info += ' · ' + res.size_kb + ' ' + (i18n.cache_kb || 'KB');
        statsEl.textContent = info;
      } catch(e) {}
    };
    xhr.send();
  }

  function doAction(btn, url, successMsg) {
    btn.disabled = true;
    var data = new URLSearchParams({ user_token: cfg.userToken });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      btn.disabled = false;
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.success) {
          var msg = successMsg + (res.entries !== undefined ? ' (' + res.entries + ')' : '');
          window.okNotify && okNotify(msg, 'success');
          loadStats();
        } else {
          window.okNotify && okNotify(res.message || 'Error', 'error');
        }
      } catch(e) {}
    };
    xhr.send(data.toString());
  }

  if (warmBtn)  warmBtn.addEventListener('click',  function () { doAction(warmBtn,  cfg.warmCacheUrl,  i18n.cache_warmed  || 'Cache warmed'); });
  if (clearBtn) clearBtn.addEventListener('click', function () { doAction(clearBtn, cfg.clearCacheUrl, i18n.cache_cleared || 'Cache cleared'); });

  document.addEventListener('click', function (e) {
    if (e.target.closest('.ok-tabs-sidebar-item[data-tab="layout-settings"]')) loadStats();
  });
  loadStats();
}());

// ── Schema.org tab ────────────────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var esc  = window.okEsc || function (s) { return String(s == null ? '' : s); };

  var tbody   = document.getElementById('ok-schema-tbody');
  var saveBtn = document.getElementById('ok-schema-save');
  var addBtn  = document.getElementById('ok-schema-add');
  var modal   = document.getElementById('ok-schema-modal');
  if (!tbody) return;

  function openModal(r) {
    r = r || {};
    document.getElementById('ok-schema-edit-id').value        = r.rule_id || '0';
    document.getElementById('ok-schema-edit-route').value     = r.route_pattern || '';
    document.getElementById('ok-schema-edit-template').value  = r.template || '';
    document.getElementById('ok-schema-edit-priority').value  = r.priority || '0';
    document.getElementById('ok-schema-edit-status').checked  = r.rule_id ? !!+r.status : true;
    document.getElementById('ok-schema-validate-result').classList.add('ok-hidden');
    if (modal) modal.classList.remove('ok-hidden');
  }
  function closeModal() { if (modal) modal.classList.add('ok-hidden'); }

  function loadRules() {
    var xhr = new XMLHttpRequest();
    xhr.open('GET', cfg.schemaListUrl, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        var items = res.items || [];
        if (!items.length) {
          tbody.innerHTML = '<tr><td colspan="5" class="text-center ok-muted">—</td></tr>';
          return;
        }
        tbody.innerHTML = items.map(function (r) {
          var preview = (r.template || '').replace(/\s+/g, ' ').slice(0, 80);
          return '<tr data-rule-id="' + r.rule_id + '" data-json=\'' + esc(JSON.stringify(r)) + '\'>' +
            '<td><code>' + esc(r.route_pattern) + '</code></td>' +
            '<td><code class="ok-text-sm">' + esc(preview) + '…</code></td>' +
            '<td>' + r.priority + '</td>' +
            '<td><span class="ok-badge ' + (+r.status ? 'ok-badge-success' : 'ok-badge-muted') + '">' + (+r.status ? 'ON' : 'OFF') + '</span></td>' +
            '<td class="ok-col-actions">' +
              '<button type="button" class="ok-btn ok-btn-icon ok-btn-sm ok-schema-edit"><i data-lucide="pencil"></i></button>' +
              '<button type="button" class="ok-btn ok-btn-icon ok-btn-sm ok-schema-delete"><i data-lucide="trash-2"></i></button>' +
            '</td></tr>';
        }).join('');
        if (window.lucide) lucide.createIcons({ nodes: tbody.querySelectorAll('[data-lucide]') });
      } catch(e) {}
    };
    xhr.send();
  }

  if (addBtn) addBtn.addEventListener('click', function () { openModal(); });
  var cancel = document.getElementById('ok-schema-edit-cancel');
  var close  = document.getElementById('ok-schema-modal-close');
  if (cancel) cancel.addEventListener('click', closeModal);
  if (close)  close.addEventListener('click',  closeModal);

  tbody.addEventListener('click', function (e) {
    var tr = e.target.closest('tr'); if (!tr) return;
    if (e.target.closest('.ok-schema-edit')) {
      try { openModal(JSON.parse(tr.getAttribute('data-json') || '{}')); } catch(err) {}
    } else if (e.target.closest('.ok-schema-delete')) {
      if (!confirm('Delete rule?')) return;
      var data = new URLSearchParams({ rule_id: tr.getAttribute('data-rule-id'), user_token: cfg.userToken });
      var xhr = new XMLHttpRequest();
      xhr.open('POST', cfg.schemaDeleteUrl, true);
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function () { try { if (JSON.parse(xhr.responseText).success) loadRules(); } catch(e) {} };
      xhr.send(data.toString());
    }
  });

  var validateBtn = document.getElementById('ok-schema-validate-btn');
  if (validateBtn) validateBtn.addEventListener('click', function () {
    var tpl = document.getElementById('ok-schema-edit-template').value;
    var data = new URLSearchParams({ template: tpl, user_token: cfg.userToken });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', cfg.schemaValidateUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        var el = document.getElementById('ok-schema-validate-result');
        el.classList.remove('ok-hidden');
        if (res.success) {
          el.innerHTML = '<div class="ok-alert ok-alert-success"><i data-lucide="check-circle"></i> OK</div>';
        } else {
          el.innerHTML = '<div class="ok-alert ok-alert-danger"><i data-lucide="x-circle"></i> ' +
            esc((res.errors || []).join('; ')) + '</div>';
        }
        if (window.lucide) lucide.createIcons({ nodes: el.querySelectorAll('[data-lucide]') });
      } catch(e) {}
    };
    xhr.send(data.toString());
  });

  var editSave = document.getElementById('ok-schema-edit-save');
  if (editSave) editSave.addEventListener('click', function () {
    var data = new URLSearchParams({
      rule_id:       document.getElementById('ok-schema-edit-id').value,
      route_pattern: document.getElementById('ok-schema-edit-route').value,
      template:      document.getElementById('ok-schema-edit-template').value,
      priority:      document.getElementById('ok-schema-edit-priority').value,
      status:        document.getElementById('ok-schema-edit-status').checked ? '1' : '0',
      user_token:    cfg.userToken
    });
    var xhr = new XMLHttpRequest();
    xhr.open('POST', cfg.schemaSaveUrl, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        if (res.success) { closeModal(); loadRules(); window.okNotify && okNotify(i18n.saved || 'Saved', 'success'); }
        else { window.okNotify && okNotify(res.message || 'Error', 'error'); }
      } catch(e) {}
    };
    xhr.send(data.toString());
  });

  document.addEventListener('click', function (e) {
    if (e.target.closest('.ok-tabs-sidebar-item[data-tab="layout-schema"]')) loadRules();
  });
}());

// ── Open Graph tab — type/lang sub-tabs (settings save via global form) ──
(function () {
