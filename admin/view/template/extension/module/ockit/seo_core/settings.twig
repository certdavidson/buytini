// ── Canonical tab ─────────────────────────────────────────────────────────────
(function () {
  'use strict';
  var cfg  = window.seoCoreConfig || {};
  var i18n = window.seoCoreI18n  || {};
  var tbody    = document.getElementById('ok-canonical-tbody');
  var pager    = document.getElementById('ok-canonical-pagination');
  var filterTp = document.getElementById('ok-canonical-filter-type');
  var addBtn   = document.getElementById('ok-canonical-add');
  var saveBtn  = document.getElementById('ok-canonical-save');
  var testBtn  = document.getElementById('ok-canonical-test-btn');
  var modal    = document.getElementById('ok-canonical-modal');
  if (!tbody) return;

  var currentPage = 1;
  var esc = window.okEsc || function (s) { return String(s == null ? '' : s); };

  function loadList(page) {
    currentPage = page || 1;
    var typ = filterTp ? filterTp.value : '';
    var url = cfg.canonicalListUrl + '&page=' + currentPage + '&limit=50'
            + (typ ? '&entity_type=' + encodeURIComponent(typ) : '');
    var xhr = new XMLHttpRequest();
    xhr.open('GET', url, true);
    xhr.onload = function () {
      try {
        var res = JSON.parse(xhr.responseText);
        renderRows(res.items || []);
        if (pager && window.seoCoreFlowBuildPager) {
          pager.innerHTML = window.seoCoreFlowBuildPager(
            res.page || 1, Math.ceil((res.total || 0) / (res.per_page || 50)), 'data-canon-page'
          );
        }
        if (window.lucide) lucide.createIcons({ nodes: tbody.querySelectorAll('[data-lucide]') });
      } catch(e) {}
    };
    xhr.send();
  }

  function renderRows(items) {
    if (!items.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-center ok-muted">—</td></tr>';
      return;
    }
    tbody.innerHTML = items.map(function (r) {
      return '<tr data-meta-id="' + r.meta_id + '" data-json=\'' + esc(JSON.stringify(r)) + '\'>' +
        '<td>' + esc(i18n['type_' + r.entity_type] || r.entity_type) + '</td>' +
        '<td>' + r.entity_id + '</td>' +
        '<td>' + esc(r.entity_name || '') + '</td>' +
        '<td><code>' + esc(r.canonical) + '</code></td>' +
        '<td>' + (cfg.langMap && cfg.langMap[r.language_id] ? esc(cfg.langMap[r.language_id]) : r.language_id) + '</td>' +
        '<td class="ok-col-actions">' +
          '<button type="button" class="ok-btn ok-btn-icon ok-btn-sm ok-canonical-edit"><i data-lucide="pencil"></i></button>' +
          '<button type="button" class="ok-btn ok-btn-icon ok-btn-sm ok-canonical-delete"><i data-lucide="trash-2"></i></button>' +
        '</td></tr>';
    }).join('');
  }

  function openModal(row) {
    row = row || {};
    document.getElementById('ok-canonical-edit-meta-id').value   = row.meta_id     || '0';
    document.getElementById('ok-canonical-edit-type').value      = row.entity_type || 'product';
    document.getElementById('ok-canonical-edit-entity-id').value = row.entity_id   || '';
    document.getElementById('ok-canonical-edit-lang').value      = row.language_id || '1';
    document.getElementById('ok-canonical-edit-url').value       = row.canonical   || '';
    if (modal) modal.classList.remove('ok-hidden');
  }
  function closeModal() { if (modal) modal.classList.add('ok-hidden'); }

  if (addBtn) addBtn.addEventListener('click', function () { openModal(); });
  var cancelBtn = document.getElementById('ok-canonical-edit-cancel');
  var closeBtn  = document.getElementById('ok-canonical-modal-close');
  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
  if (closeBtn)  closeBtn.addEventListener('click',  closeModal);

  var editSaveBtn = document.getElementById('ok-canonical-edit-save');
  if (editSaveBtn) {
    editSaveBtn.addEventListener('click', function () {
      var data = new URLSearchParams({
        entity_type: document.getElementById('ok-canonical-edit-type').value,
        entity_id:   document.getElementById('ok-canonical-edit-entity-id').value,
        language_id: document.getElementById('ok-canonical-edit-lang').value,
        canonical:   document.getElementById('ok-canonical-edit-url').value,
        user_token:  cfg.userToken
      });
      var xhr = new XMLHttpRequest();
      xhr.open('POST', cfg.canonicalSaveUrl, true);
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function () {
        try {
          var res = JSON.parse(xhr.responseText);
          if (res.success) { closeModal(); loadList(1); window.okNotify && okNotify(i18n.saved || 'Saved', 'success'); }
          else { window.okNotify && okNotify(res.message || 'Error', 'error'); }
        } catch(e) {}
      };
      xhr.send(data.toString());
    });
  }

  tbody.addEventListener('click', function (e) {
    var tr = e.target.closest('tr');
    if (!tr) return;
    if (e.target.closest('.ok-canonical-edit')) {
      try { openModal(JSON.parse(tr.getAttribute('data-json') || '{}')); } catch(err) {}
    } else if (e.target.closest('.ok-canonical-delete')) {
      if (!confirm('Delete canonical override?')) return;
      var data = new URLSearchParams({ meta_id: tr.getAttribute('data-meta-id'), user_token: cfg.userToken });
      var xhr = new XMLHttpRequest();
      xhr.open('POST', cfg.canonicalDeleteUrl, true);
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function () { try { if (JSON.parse(xhr.responseText).success) loadList(currentPage); } catch(e) {} };
      xhr.send(data.toString());
    }
  });

  if (pager) pager.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-canon-page]');
    if (btn) { e.preventDefault(); loadList(parseInt(btn.getAttribute('data-canon-page'), 10)); }
  });
  if (filterTp) filterTp.addEventListener('change', function () { loadList(1); });

  if (saveBtn) {
    saveBtn.addEventListener('click', function () {
      var data = new URLSearchParams({
        canonical_pagination:   document.querySelector('input[name="canonical_pagination"]:checked').value,
        canonical_filters:      document.querySelector('input[name="canonical_filters"]:checked').value,
        canonical_cross_domain: document.querySelector('input[name="canonical_cross_domain"]').value,
        user_token: cfg.userToken
      });
      var xhr = new XMLHttpRequest();
      xhr.open('POST', cfg.canonicalSettingsUrl, true);
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function () {
        try {
          var res = JSON.parse(xhr.responseText);
          window.okNotify && okNotify(res.success ? (i18n.saved || 'Saved') : (res.message || 'Error'),
                                      res.success ? 'success' : 'error');
        } catch(e) {}
      };
      xhr.send(data.toString());
    });
  }

  if (testBtn) {
    testBtn.addEventListener('click', function () {
      var url = cfg.canonicalTestUrl
              + '&route='       + encodeURIComponent(document.getElementById('ok-canonical-test-route').value)
              + '&params='      + encodeURIComponent(document.getElementById('ok-canonical-test-params').value)
              + '&language_id=' + encodeURIComponent(document.getElementById('ok-canonical-test-lang').value);
      var xhr = new XMLHttpRequest();
      xhr.open('GET', url, true);
      xhr.onload = function () {
        try {
          var res = JSON.parse(xhr.responseText);
          var el = document.getElementById('ok-canonical-test-result');
          el.classList.remove('ok-hidden');
          el.innerHTML = '<div class="ok-alert ok-alert-success nowrap"><i data-lucide="check-circle"></i> <code>' +
            esc(res.canonical) + '</code> — <span class="ok-badge ok-badge-muted">' + esc(res.source) + '</span></div>';
          if (window.lucide) lucide.createIcons({ nodes: el.querySelectorAll('[data-lucide]') });
        } catch(e) {}
      };
      xhr.send();
    });
  }

  // Auto-load on tab switch
  document.addEventListener('click', function (e) {
    var b = e.target.closest('.ok-tabs-sidebar-item[data-tab="layout-canonical"]');
    if (b) loadList(1);
  });
}());

// ── Dashboard: warm-cache quick action ────────────────────────────────────────
(function () {
