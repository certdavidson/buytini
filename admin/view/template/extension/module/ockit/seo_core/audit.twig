{# SEO Core | © 2026 oc-kit.com | https://oc-kit.com #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="container-fluid">
    <div class="oc-kit">
      <div class="ok-panel ok-panel-sticky">

        <div class="ok-panel-header">
          <ul class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>{% endfor %}
          </ul>
        </div>

        <div class="ok-layout">
          {% include 'extension/module/ockit/seo_core/_nav.twig' %}

          <div class="ok-content">

            {# ── Run panel ── #}
            <div class="ok-block">
              <div class="ok-block-title"><i data-lucide="search"></i> {{ text_audit_run }}</div>
              <div class="ok-block-body">
                <div class="ok-filter-bar">
                  <div>
                    <label class="ok-label form-label">{{ label_regen_lang }}</label>
                    <select id="ok-audit-lang" class="ok-select">
                      {% for lang in languages %}
                      <option value="{{ lang.language_id }}">{{ lang.name }}</option>
                      {% endfor %}
                    </select>
                  </div>
                  <div class="ok-flex ok-align-end">
                    <button type="button" id="ok-audit-run" class="ok-btn ok-btn-primary ok-btn-sm">
                      <i data-lucide="search"></i> {{ button_audit_run }}
                    </button>
                  </div>
                  <div id="ok-audit-summary" style="display:none">
                    <span class="ok-badge ok-badge-error" id="ok-audit-errors">0 {{ text_level_error }}</span>
                    <span class="ok-badge ok-badge-warning" id="ok-audit-warnings">0 {{ text_level_warning }}</span>
                    <span class="ok-badge ok-badge-info" id="ok-audit-infos">0 {{ text_level_info }}</span>
                  </div>
                </div>
                <div id="ok-audit-spinner" class="ok-spinner" style="display:none">
                  <i data-lucide="loader"></i> {{ text_analyzing }}
                </div>
              </div>
            </div>

            {# ── Results ── #}
            <div class="ok-panel" id="ok-audit-results-panel" style="display:none">
              <div class="ok-panel-header">
                <span>{{ text_audit_results }}</span>
                <div class="ok-filter-bar">
                  <select id="ok-audit-filter-severity" class="ok-select ok-filter-select">
                    <option value="">{{ text_all_levels }}</option>
                    <option value="error">{{ text_level_error }}</option>
                    <option value="warning">{{ text_level_warning }}</option>
                    <option value="info">{{ text_level_info }}</option>
                  </select>
                  <select id="ok-audit-filter-type" class="ok-select ok-filter-select">
                    <option value="">{{ text_all_types }}</option>
                    <option value="product">{{ text_type_product }}</option>
                    <option value="category">{{ text_type_category }}</option>
                    <option value="manufacturer">{{ text_type_manufacturer }}</option>
                    <option value="seo_url">SEO URL</option>
                  </select>
                </div>
              </div>

              <table class="ok-table">
                <thead>
                  <tr>
                    <th class="ok-col-sm">{{ column_severity }}</th>
                    <th class="ok-col-sm">{{ column_type }}</th>
                    <th class="ok-col-sm">ID</th>
                    <th>{{ column_entity }}</th>
                    <th>{{ column_issue }}</th>
                    <th>{{ column_detail }}</th>
                  </tr>
                </thead>
                <tbody id="ok-audit-tbody"></tbody>
              </table>
              <div id="ok-audit-empty" class="ok-empty" style="display:none">{{ text_audit_empty }}</div>
            </div>

          </div>{# /ok-content #}
        </div>{# /ok-layout #}
      </div>{# /ok-panel #}
    </div>{# /oc-kit #}
  </div>
</div>
{{ footer }}

<script>
window.seoCoreConfig = {
  auditRunUrl:     '{{ audit_run_url }}',
  auditResultsUrl: '{{ audit_results_url }}',
  userToken:       '{{ user_token }}'
};
window.seoCoreI18n = {{ lang_js }};
lucide.createIcons();
</script>
