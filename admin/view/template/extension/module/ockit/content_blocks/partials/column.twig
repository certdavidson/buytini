{% set col_id    = col.col_id ?? 0 %}
{% set col_width = col.width  ?? 0 %}

<div class="cb-col" data-col-id="{{ col_id }}" data-width="{{ col_width }}"
  data-sort="{{ col.sort_order ?? 0 }}">

  <div class="cb-col-header">
    <span class="ok-handle cb-handle"><i data-lucide="menu"></i></span>

    <div class="cb-col-width-group" data-current="{{ col_width }}">
      <button type="button" class="cb-col-width-btn{% if col_width == 0 %} active{% endif %}" data-w="0" title="{{ i18n.col_width_auto }}">A</button>
      {% for w in 1..12 %}
      <button type="button" class="cb-col-width-btn{% if col_width >= w and col_width > 0 %} lit{% endif %}{% if col_width == w %} active{% endif %}" data-w="{{ w }}">{{ w }}</button>
      {% endfor %}
    </div>

    <div class="cb-col-actions ok-ml-auto">
      <div class="cb-add-el-wrap">
        <button type="button" class="ok-btn ok-btn-primary ok-btn-xs cb-btn-add-element-col"
          data-el-type="{{ add_el_type }}">
          {{ i18n.button_add_element }}
        </button>
        <div class="cb-el-dropdown" hidden>
          <button type="button" class="cb-el-dropdown-item" data-el-type="text">{{ i18n.el_text }}</button>
          <button type="button" class="cb-el-dropdown-item" data-el-type="image">{{ i18n.el_image }}</button>
          <button type="button" class="cb-el-dropdown-item" data-el-type="html">{{ i18n.el_html }}</button>
          <button type="button" class="cb-el-dropdown-item" data-el-type="video">{{ i18n.el_video }}</button>
        </div>
      </div>
      <button type="button" class="ok-btn ok-btn-default ok-btn-xs cb-btn-col-settings"
        title="{{ i18n.button_settings }}"><i data-lucide="sliders-horizontal"></i></button>
      <button type="button" class="ok-btn ok-btn-danger ok-btn-xs cb-btn-delete-col"
        title="{{ i18n.button_delete }}"><i data-lucide="trash-2"></i></button>
    </div>
  </div>

  <div class="cb-elements-wrap" data-sortable="elements">
    {% for el in col.elements ?? [] %}
      {% set el_tpl = 'extension/module/ockit/content_blocks/elements/' ~ el.element_type ~ '.twig' %}
      {% include el_tpl with {
        element:     el,
        languages:   languages,
        language_id: language_id,
        presets:     presets,
        catalog_url: catalog_url,
        i18n:        i18n
      } only %}
    {% endfor %}
  </div>

</div>
