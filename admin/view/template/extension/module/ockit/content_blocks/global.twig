{{ header }}{{ column_left }}
<div id="content">
  <div class="container-fluid">

    <div class="oc-kit">

      <div class="ok-panel ok-panel-sticky">
        <div class="ok-panel-header">
          <ul class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
            <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
            {% endfor %}
          </ul>
          <a href="{{ settings_url }}" class="ok-btn ok-btn-default ok-btn-sm">
            <i data-lucide="arrow-left"></i> {{ heading_title }}
          </a>
        </div>
      </div>

      {% if cb_form_html %}
        {{ cb_form_html }}
      {% elseif not module_status %}
        <div class="alert alert-warning ok-mt-2">
          <i data-lucide="alert-triangle"></i>
          {{ text_module_disabled }}
          <a href="{{ settings_url }}">{{ text_settings }}</a>.
        </div>
      {% endif %}

    </div>

  </div>
</div>
{{ footer }}
