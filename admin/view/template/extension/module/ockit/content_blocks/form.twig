{# Content Blocks Pro — inline editor | © 2026 oc-kit.com | https://oc-kit.com #}
<div class="oc-kit cb-editor" id="cb-editor"
  data-page-route="{{ page_route }}"
  data-page-id="{{ page_id }}"
  data-save-url="{{ save_url }}"
  data-block-url="{{ block_url }}"
  data-element-url="{{ element_url }}"
  data-duplicate-url="{{ duplicate_url }}"
  data-translate-url="{{ translate_url }}"
  data-templates-url="{{ templates_url }}"
  data-video-url="{{ video_url }}"
  data-autocomplete-url="{{ autocomplete_url }}"
  data-upload-url="{{ upload_url }}"
  data-wysiwyg="{{ wysiwyg }}">

  {# ── Toolbar ─────────────────────────────────────────────────────────────── #}
  <div class="cb-toolbar">
    <span class="cb-toolbar-title"><i data-lucide="layout-grid"></i> {{ i18n.text_content_blocks }}</span>
    <div class="cb-toolbar-filters">
      <select class="ok-select cb-filter-type" aria-label="{{ i18n.filter_by_type ?? 'Фільтр за типом' }}" title="{{ i18n.filter_by_type ?? 'Фільтр за типом' }}">
        <option value="">{{ i18n.filter_all_types ?? 'Всі типи' }}</option>
        {% for type_key, type in types %}
          <option value="{{ type_key }}">{% if attribute(i18n, 'type_' ~ type_key) is defined %}{{ attribute(i18n, 'type_' ~ type_key) }}{% else %}{{ type_key }}{% endif %}</option>
        {% endfor %}
      </select>
      <button type="button" class="ok-btn ok-btn-default ok-btn-sm" id="cb-btn-collapse-all"
        title="{{ i18n.button_collapse_all ?? 'Згорнути / розгорнути всі' }}">
        <i data-lucide="chevrons-up-down"></i>
      </button>
    </div>
    <div class="cb-toolbar-actions">
      <button type="button" class="ok-btn ok-btn-default ok-btn-sm" id="cb-btn-from-template">
        <i data-lucide="file"></i> {{ i18n.button_add_from_template }}
      </button>
      <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="cb-btn-add-block">
        <i data-lucide="plus"></i> {{ i18n.button_add_block }}
      </button>
      <button type="button" class="ok-btn ok-btn-success ok-btn-sm" id="cb-btn-save-blocks">
        <i data-lucide="save"></i> {{ i18n.button_save_blocks }}
      </button>
    </div>
  </div>

  {# ── Blocks list ──────────────────────────────────────────────────────────── #}
  <div id="cb-blocks-list" class="cb-blocks-list" data-sortable="blocks">
    {% if blocks is empty %}
    <div class="cb-empty" id="cb-empty">{{ i18n.text_no_blocks }}</div>
    {% else %}
    <div id="cb-empty" class="cb-empty" hidden>{{ i18n.text_no_blocks }}</div>
    {% endif %}

    {% for block in blocks %}
      {% set type_def = types[block.block_type] ?? {} %}
      {% include 'extension/module/ockit/content_blocks/block.twig' with {
        block:       block,
        block_type:  block.block_type,
        type_def:    type_def,
        type_name:   attribute(i18n, 'type_' ~ block.block_type) is defined ? attribute(i18n, 'type_' ~ block.block_type) : block.block_type,
        sort_order:  block.sort_order,
        languages:   languages,
        language_id: language_id,
        presets:     presets,
        catalog_url: catalog_url,
        placeholder: placeholder,
        entity_edit_urls: entity_edit_urls,
        i18n:        i18n
      } only %}
    {% endfor %}
  </div>

  {# ── Modal: Element settings ──────────────────────────────────────────────── #}
  {% include 'extension/module/ockit/content_blocks/modal_settings.twig' with {presets: presets, presets_grouped: presets_grouped, i18n: i18n} only %}

  {# ── Modal: Templates library ─────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-templates" hidden>
    <div class="cb-modal">
      <div class="cb-modal-header">
        {{ i18n.text_templates }}
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-templates">&times;</button>
      </div>
      <div class="cb-modal-body">
        <div class="ok-flex ok-gap-8 ok-mb-3">
          <select class="ok-input ok-input-sm cb-tpl-filter-type" id="cb-tpl-filter-type">
            <option value="">{{ i18n.filter_all_types }}</option>
            {% for type_key, type in types %}
            <option value="{{ type_key }}">
              {% if attribute(i18n, 'type_' ~ type_key) is defined %}{{ attribute(i18n, 'type_' ~ type_key) }}{% else %}{{ type_key }}{% endif %}
            </option>
            {% endfor %}
          </select>
        </div>
        <div id="cb-templates-list" class="cb-templates-grid"></div>
        <div id="cb-no-templates" class="ok-text-muted ok-mt-2" hidden>{{ i18n.text_no_templates }}</div>
      </div>
    </div>
  </div>

  {# ── Modal: Save as template ──────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-save-template" hidden>
    <div class="cb-modal cb-modal-sm">
      <div class="cb-modal-header">
        {{ i18n.button_save_as_template }}
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-save-template">&times;</button>
      </div>
      <div class="cb-modal-body">
        <div class="ok-form-group">
          <label class="form-label">{{ i18n.entry_template_name }}</label>
          <input type="text" id="cb-tpl-name-input" class="ok-input ok-input-sm" placeholder="{{ i18n.entry_template_name }}">
        </div>
        <div class="ok-flex ok-gap-8 ok-mt-3">
          <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="cb-btn-save-tpl-confirm">
            {{ i18n.button_save_template }}
          </button>
          <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-dismiss="cb-modal-save-template">
            {{ i18n.button_cancel }}
          </button>
        </div>
      </div>
    </div>
  </div>

  {# ── Modal: Form Builder ──────────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-form-builder" hidden>
    <div class="cb-modal cb-modal-lg">
      <div class="cb-modal-header">
        <span><i data-lucide="mail"></i> {{ i18n.form_builder_title }}</span>
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-form-builder">&times;</button>
      </div>
      <div class="cb-modal-body">

        <div class="cb-modal-tabs">
          <button type="button" class="cb-modal-tab active" data-fb-tab="general">{{ i18n.form_builder_tab_general }}</button>
          <button type="button" class="cb-modal-tab" data-fb-tab="fields">{{ i18n.form_builder_tab_fields }}</button>
        </div>

        {# ── Tab: General ── #}
        <div class="cb-modal-tab-panel active" data-fb-panel="general">
          <div class="cb-settings-grid">
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_recipient_email }}</label>
              <input type="email" id="fb-recipient" class="ok-input ok-input-sm">
            </div>
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_redirect_url }}</label>
              <input type="text" id="fb-redirect" class="ok-input ok-input-sm" placeholder="https://...">
              <small class="ok-text-muted">{{ i18n.param_redirect_url_help }}</small>
            </div>
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_captcha_enabled }}</label>
              <label class="ok-toggle-wrap ok-toggle-sm">
                <input type="checkbox" id="fb-captcha" class="ok-toggle-input">
                <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
              </label>
            </div>
          </div>

          {% if languages|length > 1 %}
          <div class="cb-lang-tabs ok-mt-3">
            {% for lang in languages %}
              <button type="button" class="cb-lang-tab fb-lang{% if lang.language_id == language_id %} active{% endif %}"
                data-lang-id="{{ lang.language_id }}">{{ lang.code|upper|slice(0,2) }}</button>
            {% endfor %}
          </div>
          {% endif %}
          {% for lang in languages %}
          <div class="cb-lang-panel fb-lang-panel{% if lang.language_id == language_id %} active{% endif %}" data-lang-id="{{ lang.language_id }}">
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_form_subject }}</label>
              <input type="text" class="ok-input ok-input-sm fb-subject" data-lang="{{ lang.language_id }}">
            </div>
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_submit_label }}</label>
              <input type="text" class="ok-input ok-input-sm fb-submit-label" data-lang="{{ lang.language_id }}">
            </div>
            <div class="ok-form-group">
              <label class="form-label">{{ i18n.param_success_message }}</label>
              <textarea class="ok-input ok-input-sm fb-success" data-lang="{{ lang.language_id }}" rows="2"></textarea>
            </div>
          </div>
          {% endfor %}
        </div>

        {# ── Tab: Fields ── #}
        <div class="cb-modal-tab-panel" data-fb-panel="fields" hidden>
          <div id="fb-fields-list" class="cb-fb-fields-list"></div>
          <button type="button" class="ok-btn ok-btn-primary ok-btn-sm ok-mt-2" id="fb-add-field">
            <i data-lucide="plus"></i> {{ i18n.form_builder_add_field }}
          </button>
        </div>

      </div>
      <div class="cb-modal-footer">
        <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="fb-save">
          <i data-lucide="check"></i> {{ i18n.button_apply }}
        </button>
        <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-dismiss="cb-modal-form-builder">
          {{ i18n.button_cancel }}
        </button>
      </div>
    </div>
  </div>

  {# ── Modal: Select block theme ────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-themes" hidden>
    <div class="cb-modal cb-modal-sm">
      <div class="cb-modal-header">
        <i data-lucide="layout-grid"></i> {{ i18n.text_select_theme }}
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-themes">&times;</button>
      </div>
      <div class="cb-modal-body">
        <div id="cb-themes-grid" class="cb-type-grid"></div>
      </div>
    </div>
  </div>

  {# ── Loader overlay (shown while adding block) ────────────────────────────── #}
  <div class="cb-add-loader" id="cb-add-loader" hidden>
    <span class="cb-add-loader-spinner"></span>
  </div>

  {# ── Modal: Choose block type ──────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-add-block" hidden>
    <div class="cb-modal">
      <div class="cb-modal-header">
        <i data-lucide="circle-plus"></i> {{ i18n.button_add_block }}
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-add-block">&times;</button>
      </div>
      <div class="cb-modal-body">
        <div class="cb-type-grid">
          {% for type_key, type in types %}
          <button type="button" class="cb-type-card" data-block-type="{{ type_key }}" data-dismiss="cb-modal-add-block">
            <span class="cb-type-card-icon">
              <img src="view/javascript/ockit/content-blocks/assets/img/types/{{ type_key }}.svg"
                   class="cb-type-card-img" alt="" onerror="this.style.display='none'">
            </span>
            <span class="cb-type-card-name">{% if attribute(i18n, 'type_' ~ type_key) is defined %}{{ attribute(i18n, 'type_' ~ type_key) }}{% else %}{{ type_key }}{% endif %}</span>
          </button>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  {# ── Modal: Translate ─────────────────────────────────────────────────────── #}
  <div class="cb-modal-backdrop" id="cb-modal-translate" hidden>
    <div class="cb-modal cb-modal-sm">
      <div class="cb-modal-header">
        {{ i18n.button_translate }}
        <button type="button" class="cb-modal-close" data-dismiss="cb-modal-translate">&times;</button>
      </div>
      <div class="cb-modal-body">
        <div class="ok-form-row ok-mb-2">
          <label class="form-label ok-fw-600">{{ i18n.text_translate_from ?? 'З мови' }}</label>
          <select id="cb-translate-lang-from" class="ok-input ok-input-sm">
            {% for lang in languages %}
            <option value="{{ lang.code }}" data-lang-id="{{ lang.language_id }}"{% if lang.language_id == language_id %} selected{% endif %}>{{ lang.name }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="ok-form-row ok-mb-3">
          <label class="form-label ok-fw-600">{{ i18n.text_translate_to ?? 'На мову' }}</label>
          <select id="cb-translate-lang" class="ok-input ok-input-sm">
            {% for lang in languages %}
            <option value="{{ lang.code }}" data-lang-id="{{ lang.language_id }}"{% if lang.language_id != language_id and loop.first %} selected{% endif %}>{{ lang.name }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="ok-flex ok-gap-8">
          <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="cb-btn-translate-confirm">
            <i data-lucide="languages"></i> {{ i18n.button_translate }}
          </button>
          <button type="button" class="ok-btn ok-btn-default ok-btn-sm" data-dismiss="cb-modal-translate">
            {{ i18n.button_cancel }}
          </button>
        </div>
        <div id="cb-translate-status" class="ok-mt-2 ok-text-muted" hidden></div>
      </div>
    </div>
  </div>

</div>{# /cb-editor #}

<script>
window.cbI18n       = {{ i18n|json_encode }};
window.cbTypes      = {{ types|json_encode }};
window.cbPresets    = {{ presets|json_encode }};
window.cbTemplates  = {{ templates|json_encode }};
window.cbLanguages  = {{ languages|json_encode }};
window.cbLanguageId = {{ language_id }};
</script>
