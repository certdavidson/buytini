{% set el_id     = element.element_id ?? 0 %}
{% set el_params = element.params     ?? {} %}
{% set cat_id    = el_params.category_id   ?? 0 %}
{% set cat_name  = el_params.category_name ?? '' %}
{% set cat_img   = el_params.category_img  ?? '' %}

<div class="cb-element cb-item cb-item-compact" data-el-id="{{ el_id }}" data-el-type="categories_item"
  data-sort="{{ element.sort_order ?? 0 }}">

  <div class="cb-element-header">
    <span class="ok-handle cb-handle"><i data-lucide="menu"></i></span>
    {% if cat_img %}
    <img src="{{ cat_img }}" class="cb-item-thumb" alt="">
    {% endif %}
    {% if cat_name %}
      <a class="cb-item-label ok-text-sm ok-ml-2" href="{{ entity_edit_urls.category|default('')|replace({'{ID}': cat_id}) }}" target="_blank" rel="noopener">{{ cat_name }}</a>
    {% else %}
      <span class="cb-item-label ok-text-sm ok-ml-2">{{ i18n.text_pick_category }}</span>
    {% endif %}
    <input type="hidden" class="cb-ac-val" value="{{ cat_id }}">
    <input type="hidden" class="cb-ac-name" value="{{ cat_name }}">
    <input type="hidden" class="cb-ac-img" value="{{ cat_img }}">
    <div class="cb-el-actions ok-ml-auto">
      <button type="button" class="ok-btn ok-btn-danger ok-btn-xs cb-btn-delete-el"
        title="{{ i18n.button_delete }}"><i data-lucide="trash-2"></i></button>
    </div>
  </div>

  <div class="cb-autocomplete-panel"{% if cat_id %} hidden{% endif %}>
    <div class="cb-autocomplete-wrap" data-type="category">
      <input type="text" class="ok-input ok-input-sm cb-autocomplete-input" placeholder="{{ i18n.placeholder_search_category }}">
      <div class="cb-autocomplete-dropdown" hidden></div>
    </div>
  </div>

</div>
