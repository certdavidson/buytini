{# Advanced Search | © 2024-2026 oc-kit.com | https://oc-kit.com #}
{{ header }}{{ column_left }}
<div id="content">
  <div class="container-fluid">

    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible">
      <i data-lucide="alert-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    <div class="oc-kit">
      <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-asp" class="ok-panel ok-panel-sticky">

        <div class="ok-panel-header">
          <ul class="breadcrumb">
            <li><a href="{{ cancel }}">{{ text_extension }}</a></li>
            <li><a href="#">{{ heading_title }}</a></li>
          </ul>
          <div class="ok-flex ok-gap-8">
            <button type="submit" class="ok-btn ok-btn-primary ok-btn-sm"><i data-lucide="save"></i> {{ button_save }}</button>
            <a href="{{ cancel }}" class="ok-btn ok-btn-default ok-btn-sm">{{ button_cancel }}</a>
          </div>
        </div>

        <div id="asp">
          <div class="ok-layout">

            {# ── Sidebar ─────────────────────────────────────────────────── #}
            <div class="ok-sidebar">

              <div class="ok-brand">
                <div class="ok-brand-icon"><i data-lucide="search"></i></div>
                <a href="https://oc-kit.com" target="_blank" class="ok-brand-logo">oc-kit.com</a>
                <span class="ok-brand-name">Advanced Search <span class="ok-brand-version">v{{ asp_module_version }}</span></span>
              </div>

              <div class="ok-tabs-sidebar">

                <button type="button" class="ok-tabs-sidebar-item{% if wizard_done %} active{% endif %}" data-tab="tab-stats">
                  <i data-lucide="bar-chart-2"></i> {{ tab_stats }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-zero-results">
                  <i data-lucide="search-x"></i> {{ tab_zero_results }}
                </button>

                <hr class="ok-divider ok-divider--nav">

                <button type="button" class="ok-tabs-sidebar-item{% if not wizard_done %} ok-tabs-sidebar-item--pulse{% endif %}" data-tab="tab-wizard">
                  <i data-lucide="wand-2"></i> {{ tab_wizard }}
                  {% if wizard_done %}
                    <span class="ok-badge ok-badge-success ok-badge-sm ok-badge-squared ok-ml-auto"><i data-lucide="check"></i></span>
                  {% else %}
                    <span class="ok-badge ok-badge-warning ok-badge-sm ok-badge-squared ok-ml-auto"><i data-lucide="circle-x"></i></span>
                  {% endif %}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-general">
                  <i data-lucide="power"></i> {{ tab_general }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-search">
                  <i data-lucide="search"></i> {{ tab_search }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-autocomplete">
                  <i data-lucide="zap"></i> {{ tab_autocomplete }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item is-disabled" data-tab="tab-filters" disabled title="{{ text_coming_soon }}">
                  <i data-lucide="filter"></i> {{ tab_filters }}
                  <span class="asp-soon-badge">{{ text_soon }}</span>
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-attributes">
                  <i data-lucide="list"></i> {{ tab_attributes }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-synonyms">
                  <i data-lucide="shuffle"></i> {{ tab_synonyms }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-ai">
                  <i data-lucide="wand-2"></i> AI
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-query-rules">
                  <i data-lucide="list"></i> {{ tab_query_rules }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-index">
                  <i data-lucide="database"></i> {{ tab_index }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-daemons">
                  <i data-lucide="server"></i> {{ tab_daemons }}
                </button>

                <hr class="ok-divider ok-divider--nav">

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-dictionary">
                  <i data-lucide="book"></i> {{ tab_dictionary }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-faq">
                  <i data-lucide="help-circle"></i> {{ tab_faq }}
                </button>

                <button type="button" class="ok-tabs-sidebar-item" data-tab="tab-license">
                  <i data-lucide="key-round"></i> {{ tab_license }}
                </button>

              </div>
            </div>

            {# ── Content ─────────────────────────────────────────────────── #}
            <div class="ok-content">

              {# ══ WIZARD ══════════════════════════════════════════════════ #}
              <div class="ok-layout-panel{% if not wizard_done %} active{% endif %}" id="tab-wizard">

                {% if wizard_done %}
                <div class="ok-block">
                  <div class="ok-block-title"><i data-lucide="check-circle-2"></i> {{ tab_wizard }}</div>
                  <div class="ok-block-body">
                    <div class="ok-alert ok-alert-success ok-mb-3"><i data-lucide="check-circle-2"></i> {{ text_wizard_done_msg }}</div>
                    <p class="ok-help ok-mb-3">{{ text_wizard_done_hint }}</p>

                    <table class="asp-wiz-summary ok-mb-3">
                      <tr>
                        <td class="ok-text-muted">{{ text_wiz_summary_mode }}</td>
                        <td><span class="ok-badge ok-badge-info-soft">{{ wizard_current_mode }}</span></td>
                      </tr>
                      <tr>
                        <td class="ok-text-muted">{{ text_wiz_summary_ai }}</td>
                        <td>{% if wizard_current_ai %}<span class="ok-badge ok-badge-success-soft">{{ text_wiz_enabled }}</span>{% else %}<span class="ok-badge ok-badge-muted">{{ text_wiz_skipped }}</span>{% endif %}</td>
                      </tr>
                      <tr>
                        <td class="ok-text-muted">{{ text_wiz_summary_cron }}</td>
                        <td>{% if wizard_current_cron %}<span class="ok-badge ok-badge-success-soft">{{ text_wiz_enabled }}</span>{% else %}<span class="ok-badge ok-badge-muted">{{ text_wiz_skipped }}</span>{% endif %}</td>
                      </tr>
                    </table>
                  </div>

                  <div class="ok-panel-footer">
                    <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="asp-wiz-reset" data-url="{{ wizard_reset_url }}">
                      <i data-lucide="undo-2"></i> {{ button_wiz_reset }}
                    </button>
                  </div>
                  
                </div>
                {% else %}

                {# Intro #}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="wand-2"></i> {{ tab_wizard }}</div>
                  <div class="ok-block-body">
                    <p class="ok-help">{{ text_wizard_intro }}</p>
                  </div>
                </div>

                {# Step 1 — Engine (quiz cards) #}
                <div class="ok-block ok-mb-2">
                  <div class="ok-block-title"><span class="ok-badge ok-badge-primary ok-badge-sm ok-mr-1">1</span> {{ text_wiz_mode_title }}</div>
                  <div class="ok-block-body">
                    <div class="ok-quiz-cards-lg" id="wiz-mode-cards">
                      <div class="ok-quiz-card-lg wiz-mode-card selected" data-value="native">
                        <span class="ok-quiz-card-lg-icon"><i data-lucide="database"></i></span>
                        <div class="ok-quiz-card-lg-title">{{ text_native }}</div>
                        <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_native }}</div>
                        <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:40%"></div></div>
                      </div>
                      <div class="ok-quiz-card-lg wiz-mode-card" data-value="manticore">
                        <span class="ok-quiz-card-lg-icon"><i data-lucide="zap"></i></span>
                        <div class="ok-quiz-card-lg-title">Manticore</div>
                        <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_manticore }}</div>
                        <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:80%"></div></div>
                      </div>
                      <div class="ok-quiz-card-lg wiz-mode-card" data-value="sphinx">
                        <span class="ok-quiz-card-lg-icon"><i data-lucide="zoom-in"></i></span>
                        <div class="ok-quiz-card-lg-title">Sphinx</div>
                        <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_sphinx }}</div>
                        <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:55%"></div></div>
                      </div>
                      <div class="ok-quiz-card-lg wiz-mode-card" data-value="hybrid">
                        <span class="ok-quiz-card-lg-icon"><i data-lucide="wand-2"></i></span>
                        <div class="ok-quiz-card-lg-title">Hybrid</div>
                        <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_hybrid }}</div>
                        <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:95%"></div></div>
                      </div>
                    </div>
                    <input type="hidden" id="wiz-mode" value="native">
                  </div>
                </div>

                {# Step 2 — Connection (shown for non-native modes) #}
                <div class="ok-block ok-mb-2 asp-wiz-block" id="wiz-conn-block" style="display:none">
                  <div class="ok-block-title"><span class="ok-badge ok-badge-primary ok-badge-sm ok-mr-1">2</span> {{ text_wiz_conn_title }}</div>
                  <div class="ok-block-body">
                    <p class="ok-help ok-mb-2">{{ text_wizard_conn_hint }}</p>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_host }}</label>
                      <div>
                        <input type="text" class="ok-input ok-w-200" id="wiz-host" value="127.0.0.1">
                      </div>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_port }}</label>
                      <div>
                        <input type="text" class="ok-input ok-w-100" id="wiz-port" value="9306">
                      </div>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_index_name }}</label>
                      <div>
                        <input type="text" class="ok-input ok-w-180" id="wiz-index" value="products">
                      </div>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_login }}</label>
                      <div>
                        <input type="text" class="ok-input ok-w-180" id="wiz-login" value="">
                      </div>
                    </div>
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_password }}</label>
                      <div>
                        <input type="password" class="ok-input ok-w-180" id="wiz-password" value="">
                      </div>
                    </div>
                  </div>
                </div>

                {# Step 3 — AI #}
                <div class="ok-block ok-mb-2 asp-wiz-block">
                  <div class="ok-block-title"><span class="ok-badge ok-badge-primary ok-badge-sm ok-mr-1">3</span> {{ text_wiz_ai_title }}</div>
                  <div class="ok-block-body">
                    <div class="ok-form-row">
                      <label class="ok-label form-label">AI</label>
                      <div>
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" id="wiz-ai">
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ text_wizard_ai_hint }}</p>
                      </div>
                    </div>
                    <div class="ok-form-row" id="wiz-ai-key-row" style="display:none">
                      <label class="ok-label form-label">{{ entry_api_key }}</label>
                      <div>
                        <input type="text" class="ok-input ok-w-340" id="wiz-ai-key" placeholder="sk-...">
                        <p class="ok-help ok-mt-1">{{ text_wizard_ai_key_hint }}</p>
                      </div>
                    </div>
                  </div>
                </div>

                {# Step 4 — Cron #}
                <div class="ok-block ok-mb-2 asp-wiz-block">
                  <div class="ok-block-title"><span class="ok-badge ok-badge-primary ok-badge-sm ok-mr-1">4</span> {{ text_wiz_cron_title }}</div>
                  <div class="ok-block-body">
                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_autoindex }}</label>
                      <div>
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" id="wiz-cron" checked>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ text_wizard_cron_hint }}</p>
                      </div>
                    </div>
                  </div>
                </div>

                {# Apply #}
                <div class="ok-py-2">
                  <div class="ok-flex ok-gap-8 ok-items-center">
                    <button type="button" class="ok-btn ok-btn-primary" id="asp-wiz-apply" data-url="{{ wizard_url }}" data-redirect="{{ action }}">
                      <i data-lucide="check"></i> {{ button_wiz_apply }}
                    </button>
                    <span id="asp-wiz-status" class="ok-help"></span>
                  </div>
                </div>

                {% endif %}
              </div>

              {# ══ GENERAL ═════════════════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-general">

                {% if asp_presets %}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="layers"></i> {{ text_niche_presets }}</div>
                  <div class="ok-block-body">
                    <p class="ok-help ok-mb-2">{{ help_niche_presets }}</p>
                    <div class="ok-flex ok-gap-8 ok-mb-2" style="flex-wrap:wrap" data-preset-url="{{ asp_load_preset_url }}">
                      {% for preset in asp_presets %}
                        <button type="button" class="ok-btn ok-btn-default ok-btn-sm asp-preset-btn" data-code="{{ preset.code }}" title="{{ preset.description }}">
                          {{ preset.name }}{% if preset.syn_count %} <span class="ok-badge ok-badge-success-soft ok-badge-sm">+{{ preset.syn_count }}</span>{% endif %}
                        </button>
                      {% endfor %}
                    </div>
                    <div id="asp-preset-status" class="ok-hidden"></div>
                  </div>
                </div>
                {% endif %}

                <div class="ok-block">
                  <div class="ok-block-title"><i data-lucide="power"></i> {{ tab_general }}</div>
                  <div class="ok-block-body">

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_status }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_status" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_status" value="1" {% if module_oc_kit_advanced_search_pro_status %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_search_type }}</label>
                      <div>
                        <div class="ok-quiz-cards-lg">
                          <div class="ok-quiz-card-lg asp-pick-card {% if module_oc_kit_advanced_search_pro_mode == 'native' or not module_oc_kit_advanced_search_pro_mode %}selected{% endif %}" data-value="native" data-input="asp-mode">
                            <span class="ok-quiz-card-lg-icon"><i data-lucide="database"></i></span>
                            <div class="ok-quiz-card-lg-title">{{ text_native }}</div>
                            <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_native }}</div>
                            <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:40%"></div></div>
                          </div>
                          <div class="ok-quiz-card-lg asp-pick-card {% if module_oc_kit_advanced_search_pro_mode == 'manticore' %}selected{% endif %}" data-value="manticore" data-input="asp-mode">
                            <span class="ok-quiz-card-lg-icon"><i data-lucide="zap"></i></span>
                            <div class="ok-quiz-card-lg-title">{{ text_manticore }}</div>
                            <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_manticore }}</div>
                            <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:80%"></div></div>
                          </div>
                          <div class="ok-quiz-card-lg asp-pick-card {% if module_oc_kit_advanced_search_pro_mode == 'sphinx' %}selected{% endif %}" data-value="sphinx" data-input="asp-mode">
                            <span class="ok-quiz-card-lg-icon"><i data-lucide="zoom-in"></i></span>
                            <div class="ok-quiz-card-lg-title">{{ text_sphinx }}</div>
                            <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_sphinx }}</div>
                            <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:55%"></div></div>
                          </div>
                          <div class="ok-quiz-card-lg asp-pick-card {% if module_oc_kit_advanced_search_pro_mode == 'hybrid' %}selected{% endif %}" data-value="hybrid" data-input="asp-mode">
                            <span class="ok-quiz-card-lg-icon"><i data-lucide="wand-2"></i></span>
                            <div class="ok-quiz-card-lg-title">{{ text_hybrid }}</div>
                            <div class="ok-quiz-card-lg-desc">{{ text_wiz_hint_hybrid }}</div>
                            <div class="ok-quiz-card-lg-eff"><div class="ok-quiz-card-lg-eff-bar" style="width:95%"></div></div>
                          </div>
                        </div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_mode" id="asp-mode" value="{{ module_oc_kit_advanced_search_pro_mode|default('native') }}">
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_debug_mode }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_debug" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_debug" value="1" {% if module_oc_kit_advanced_search_pro_debug %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                      </div>
                    </div>

                  </div>
                </div>

              </div>

              {# ══ SEARCH ══════════════════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-search">

                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="sliders"></i> {{ text_algorithm_params }}</div>
                  <div class="ok-block-body">

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_layout_correction }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_layout_correction" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_layout_correction" value="1" {% if module_oc_kit_advanced_search_pro_layout_correction %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ help_layout_correction | raw }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_cross_lang_enabled }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_cross_lang_enabled" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_cross_lang_enabled" value="1" {% if module_oc_kit_advanced_search_pro_cross_lang_enabled %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help">{{ help_cross_lang_enabled }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label ok-mt-1">{{ entry_fuzzy }}</label>
                      <div>
                        <div class="ok-input-inline">
                          <input type="hidden" name="module_oc_kit_advanced_search_pro_fuzzy" value="0">
                          <label class="ok-toggle-wrap">
                            <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_fuzzy" value="1" {% if module_oc_kit_advanced_search_pro_fuzzy %}checked{% endif %}>
                            <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                          </label>
                          <label class="ok-label form-label ok-ml-4 ok-mb-0 ok-pb-0">{{ entry_fuzzy_distance }}</label>
                          <input type="text" name="module_oc_kit_advanced_search_pro_fuzzy_distance" value="{{ module_oc_kit_advanced_search_pro_fuzzy_distance }}" class="ok-input ok-w-70" min="1" max="3">
                        </div>
                        <p class="ok-help ok-mt-1">{{ help_fuzzy | raw }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_min_word_length }}</label>
                      <input type="text" name="module_oc_kit_advanced_search_pro_min_word_length" value="{{ module_oc_kit_advanced_search_pro_min_word_length }}" class="ok-input ok-w-70" min="1" max="10">
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_stopwords }}</label>
                      <div>
                        <textarea name="module_oc_kit_advanced_search_pro_stopwords" class="ok-input ok-w-500" rows="4" placeholder="{{ placeholder_stopwords }}">{{ module_oc_kit_advanced_search_pro_stopwords }}</textarea>
                        <p class="ok-help ok-mt-1">{{ help_stopwords }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_wordforms }}</label>
                      <div>
                        <textarea name="module_oc_kit_advanced_search_pro_wordforms" class="ok-input ok-w-500" rows="4" placeholder="{{ placeholder_wordforms }}">{{ module_oc_kit_advanced_search_pro_wordforms }}</textarea>
                        <p class="ok-help ok-mt-1">{{ help_config_only }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_lemmatization }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_lemmatization" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_lemmatization" value="1" {% if module_oc_kit_advanced_search_pro_lemmatization %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ help_lemmatization | raw }}</p>
                      </div>
                    </div>

                  </div>
                </div>

                {# ── NLP & Query Intelligence ────────────────────────────── #}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="wand-2"></i> {{ text_nlp_features }}</div>
                  <div class="ok-block-body">

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ entry_homoglyph_norm }}</label>
                      <div>
