                            <td>
                              {% if q.has_rule %}
                                <span class="ok-badge ok-badge-success ok-badge-squared ok-badge-sm"><i data-lucide="check"></i> {# text_rule_exists #}</span>
                              {% else %}
                                <span class="ok-badge ok-badge-muted ok-badge-squared ok-badge-sm"><i data-lucide="x"></i> {# text_no_rule #}</span>
                              {% endif %}
                            </td>
                            <td>
                              {% if not q.has_rule %}
                              <button type="button" class="ok-btn ok-btn-default ok-btn-sm asp-gen-rule-for" data-query="{{ q.query }}">
                                <i class="ok-mr-1" data-lucide="wand-2"></i> {{ text_generate_rule }}
                              </button>
                              {% endif %}
                            </td>
                          </tr>
                          {% endfor %}
                        {% else %}
                          <tr><td colspan="4" class="ok-text-center ok-text-muted">{{ text_no_data }}</td></tr>
                        {% endif %}
                      </tbody>
                    </table>
                  </div>

                  <div class="ok-block">
                    <div class="ok-block-title">
                      <i data-lucide="star"></i> {{ text_top_queries }}
                    </div>
                    <table class="ok-table">
                      <thead>
                        <tr>
                          <th>{{ text_col_query }}</th>
                          <th>{{ text_col_count }}</th>
                          <th>{{ text_col_last_seen }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% if stats.top_queries %}
                          {% for q in stats.top_queries %}
                          <tr>
                            <td>{{ q.query }}</td>
                            <td>{{ q.count }}</td>
                            <td>{{ q.last_seen }}</td>
                          </tr>
                          {% endfor %}
                        {% else %}
                          <tr><td colspan="3" class="ok-text-center ok-text-muted">{{ text_no_data }}</td></tr>
                        {% endif %}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title">
                    <i data-lucide="history"></i> {{ text_recent_queries }}
                  </div>
                  <div class="ok-table-scroll">
                    <table class="ok-table">
                      <thead>
                        <tr>
                          <th>{{ text_col_query }}</th>
                          <th>{{ text_col_count }}</th>
                          <th>{{ text_col_results }}</th>
                          <th>{{ text_col_date }}</th>
                        </tr>
                      </thead>
                      <tbody>
                        {% if stats.recent_queries %}
                          {% for q in stats.recent_queries %}
                          <tr>
                            <td>{{ q.query }}</td>
                            <td>{{ q.hits }}</td>
                            <td>
                              {% if q.results > 0 %}
                                <span class="ok-badge ok-badge-success ok-badge-sm">{{ q.results }}</span>
                              {% else %}
                                <span class="ok-badge ok-badge-danger ok-badge-sm">0</span>
                              {% endif %}
                            </td>
                            <td>{{ q.created_at }}</td>
                          </tr>
                          {% endfor %}
                        {% else %}
                          <tr><td colspan="4" class="ok-text-center ok-text-muted">{{ text_no_data }}</td></tr>
                        {% endif %}
                      </tbody>
                    </table>
                  </div>
                </div>

                <div class="ok-block">
                  <div class="ok-block-title"><i data-lucide="flask-conical"></i> {{ text_benchmark }}</div>
                  <div class="ok-block-body">
                    <div class="ok-flex ok-gap-8 ok-mb-2 ok-items-center">
                      <button type="button" class="ok-btn ok-btn-default ok-btn-sm" id="asp-run-benchmark" data-url="{{ asp_benchmark_url }}"><i data-lucide="play"></i> {{ button_run_benchmark }}</button>
                      <span id="asp-benchmark-status" class="ok-help"></span>
                    </div>
                    <pre class="ok-pre" id="asp-benchmark-result" style="display:none">{{ text_benchmark_report_placeholder }}</pre>
                    <div id="asp-benchmark-interpret" class="ok-hidden ok-mt-3"
                         data-text-excellent="{{ text_bench_excellent }}" data-text-good="{{ text_bench_good }}"
                         data-text-acceptable="{{ text_bench_acceptable }}" data-text-slow="{{ text_bench_slow }}"
                         data-tip-native="{{ text_bench_tip_native_ok }}" data-tip-mant="{{ text_bench_tip_mant_ok }}"
                         data-tip-slow="{{ text_bench_tip_slow }}" data-tip-hybrid="{{ text_bench_tip_hybrid }}">
                      <div class="ok-fw-600 ok-mb-2">{{ text_bench_interpret }}</div>
                      <table class="ok-table">
                        <thead><tr>
                          <th>{{ text_bench_metric }}</th>
                          <th>{{ text_bench_value }}</th>
                          <th>{{ text_bench_rating }}</th>
                          <th>{{ text_bench_tip }}</th>
                        </tr></thead>
                        <tbody id="asp-bench-interpret-body"></tbody>
                      </table>
                    </div>
                  </div>
                </div>

              </div>

              {# ══ ZERO-RESULT QUERIES ═════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-zero-results">

                <div class="ok-block">
                  <div class="ok-block-title">
                    <i data-lucide="search-x"></i> {{ text_all_zero_queries }}

                    <div class="ok-flex ok-gap-16 ok-items-center ok-mb-2 ok-hidden ok-ml-auto" id="asp-zero-bulk-bar">
                      <span id="asp-zero-bulk-count" class="ok-help"></span>
                      <button type="button" class="ok-btn ok-btn-primary ok-btn-sm" id="asp-zero-bulk-generate" data-url="{{ asp_generate_rule_for_url }}">
                        <i data-lucide="wand-2"></i> {{ text_generate_rule }}
                      </button>
                    </div>
                  </div>
                  <div class="ok-block-body">
                    <p class="ok-help ok-mb-2">{{ text_zero_results_hint }}</p>

                    

                    <div class="ok-table-scroll">
                      <table class="ok-table" id="asp-all-zero-table" data-url="{{ asp_generate_rule_for_url }}">
                        <thead>
                          <tr>
                            <th class="ok-col-40 ok-text-center">
                              <label class="ok-checkbox" title="{{ text_select_all }}">
                                <input type="checkbox" id="asp-zero-check-all">
                              </label>
                            </th>
                            <th>{{ text_col_query }}</th>
                            <th>{{ text_col_date }}</th>
                            <th>{{ text_col_has_rule }}</th>
                            <th></th>
                          </tr>
                        </thead>
                        <tbody>
                          {% if stats.all_no_result_queries %}
                            {% for q in stats.all_no_result_queries %}
                            <tr data-query="{{ q.query }}" {% if q.has_rule %}class="asp-zero-has-rule"{% endif %}>
                              <td class="ok-text-center">
                                <label class="ok-checkbox">
                                  <input type="checkbox" class="asp-zero-row-check" {% if q.has_rule %}disabled{% endif %}>
                                </label>
                              </td>
                              <td>{{ q.query }}</td>
                              <td>{{ q.created_at }}</td>
                              <td>
                                {% if q.has_rule %}
                                  <span class="ok-badge ok-badge-success ok-badge-sm ok-badge-squared"><i data-lucide="check"></i></span>
                                {% else %}
                                  <span class="ok-badge ok-badge-muted ok-badge-sm ok-badge-squared"><i data-lucide="x"></i></span>
                                {% endif %}
                              </td>
                              <td>
                                {% if q.has_rule %}
                                  <button type="button" class="ok-btn ok-btn-default ok-btn-sm" disabled>
                                    <i class="ok-mr-1" data-lucide="check"></i> {{ text_rule_generated }}
                                  </button>
                                {% else %}
                                  <button type="button" class="ok-btn ok-btn-default ok-btn-sm asp-gen-rule-for" data-query="{{ q.query }}">
                                    <i class="ok-mr-1" data-lucide="wand-2"></i> {{ text_generate_rule }}
                                  </button>
                                {% endif %}
                              </td>
                            </tr>
                            {% endfor %}
                          {% else %}
                            <tr><td colspan="5" class="ok-text-center ok-text-muted">{{ text_no_data }}</td></tr>
                          {% endif %}
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>

              </div>

              {# ══ DICTIONARY ══════════════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-dictionary">

                {# NLP toggles #}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="languages"></i> {{ tab_dictionary }}</div>
                  <div class="ok-block-body">
                    <p class="ok-help ok-mb-3">{{ dict_description }}</p>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ dict_label_morphology }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_enable_morphology" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_enable_morphology" value="1" {% if module_oc_kit_advanced_search_pro_enable_morphology %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ dict_hint_morphology }}</p>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ dict_label_trigram }}</label>
                      <div>
                        <input type="hidden" name="module_oc_kit_advanced_search_pro_enable_trigram_fallback" value="0">
                        <label class="ok-toggle-wrap">
                          <input type="checkbox" class="ok-toggle-input" name="module_oc_kit_advanced_search_pro_enable_trigram_fallback" value="1" {% if module_oc_kit_advanced_search_pro_enable_trigram_fallback %}checked{% endif %}>
                          <span class="ok-toggle-track"><span class="ok-toggle-thumb"></span></span>
                        </label>
                        <p class="ok-help ok-mt-1">{{ dict_hint_trigram }}</p>
                      </div>
                    </div>
                  </div>
                </div>

                {# Stats #}
                <div class="ok-block ok-mb-3" id="dict-stats">
                  <div class="ok-block-title"><i data-lucide="bar-chart-2"></i> {{ dict_col_lang }} / {{ dict_col_count }}</div>
                  <div class="ok-block-body-flush">
                    <table class="ok-table ok-table--compact">
                      <thead><tr>
                        <th>{{ dict_col_lang }}</th>
                        <th>{{ dict_col_count }}</th>
                        <th>{{ dict_col_actions }}</th>
                      </tr></thead>
                      <tbody>
                        {% for lang_key, cnt in asp_dict_counts %}
                          <tr>
                            <td>{% if lang_key == '' %}{{ dict_lang_all }}{% else %}{{ lang_key | upper }}{% endif %}</td>
                            <td><span class="ok-badge">{{ cnt }}</span></td>
                            <td>
                              <button type="button" class="ok-btn ok-btn-sm ok-btn-danger dict-delete-btn"
                                data-lang="{{ lang_key }}">{{ button_delete }}</button>
                            </td>
                          </tr>
                        {% else %}
                          <tr><td colspan="3" class="ok-text-muted ok-px-3 ok-py-2">{{ dict_empty }}</td></tr>
                        {% endfor %}
                      </tbody>
                    </table>
                  </div>
                </div>

                {# Import form #}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="upload"></i> {{ dict_import_title }}</div>
                  <div class="ok-block-body">
                    <p class="ok-help ok-mb-3">{{ dict_import_hint }}</p>

                    <div class="ok-form-row">
                      <label class="ok-label form-label" for="dict-lang-select">{{ dict_import_lang }}</label>
                      <select id="dict-lang-select" class="ok-select ok-w-140">
                        <option value="">{{ dict_lang_all }}</option>
                        <option value="uk">UK</option>
                        <option value="ru">RU</option>
                        <option value="en">EN</option>
                      </select>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label" for="dict-file-input">{{ dict_import_file }}</label>
                      <input type="file" id="dict-file-input" accept=".csv,.json" class="ok-input ok-w-340">
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label"></label>
                      <div>
                        <button type="button" id="dict-import-btn" class="ok-btn ok-btn-primary">
                          <i data-lucide="upload"></i> {{ dict_import_btn }}
                        </button>
                        <span id="dict-import-result" class="ok-text-muted ok-ml-2"></span>
                      </div>
                    </div>

                    <div class="ok-form-row">
                      <label class="ok-label form-label">{{ dict_format_title }}</label>
                      <div>
                        <pre class="ok-pre">{{ dict_format_csv }}</pre>
                        <pre class="ok-pre">{{ dict_format_json }}</pre>
                      </div>
                    </div>
                  </div>
                </div>

                {# Entries preview #}
                <div class="ok-block ok-mb-3" id="dict-preview-wrap" style="display:none">
                  <div class="ok-block-title"><i data-lucide="list"></i> {{ dict_preview_title }} <span id="dict-preview-total" class="ok-text-muted ok-text-sm"></span></div>
                  <div class="ok-block-body">
                    <div class="ok-flex ok-gap-8 ok-mb-2">
                      <select id="dict-preview-lang" class="ok-select ok-w-140">
                        <option value="">{{ dict_lang_all }}</option>
                        <option value="uk">UK</option>
                        <option value="ru">RU</option>
                        <option value="en">EN</option>
                      </select>
                      <button type="button" id="dict-preview-btn" class="ok-btn ok-btn-sm">{{ dict_preview_btn }}</button>
                    </div>
                  </div>
                  <div class="ok-block-body-flush">
                    <table class="ok-table" id="dict-preview-table">
                      <thead><tr>
                        <th>{{ dict_col_word }}</th>
                        <th>{{ dict_col_stem }}</th>
                        <th>{{ dict_col_lang }}</th>
                      </tr></thead>
                      <tbody id="dict-preview-body"></tbody>
                    </table>
                  </div>
                  <div class="ok-block-body">
                    <div id="dict-preview-pager" class="ok-text-muted ok-text-sm"></div>
                  </div>
                </div>

              </div>

              {# ══ FAQ ═════════════════════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-faq">

                {% set faq_items = [
                  ['faq_section_engines',     [['faq_native_title','faq_native_text'],['faq_manticore_title','faq_manticore_text'],['faq_sphinx_title','faq_sphinx_text'],['faq_hybrid_title','faq_hybrid_text']]],
                  ['faq_section_search',      [['faq_fuzzy_title','faq_fuzzy_text'],['faq_layout_title','faq_layout_text'],['faq_morphology_title','faq_morphology_text'],['faq_ratio_title','faq_ratio_text'],['faq_min_score_title','faq_min_score_text'],['faq_fields_title','faq_fields_text'],['faq_synonyms_title','faq_synonyms_text'],['faq_zero_results_title','faq_zero_results_text']]],
                  ['faq_section_indexing',    [['faq_indexing_title','faq_indexing_text'],['faq_cron_title','faq_cron_text']]],
                  ['faq_section_autocomplete',[['faq_autocomplete_title','faq_autocomplete_text'],['faq_facets_title','faq_facets_text']]],
                  ['faq_section_ai',          [['faq_embeddings_title','faq_embeddings_text'],['faq_ai_rewrite_title','faq_ai_rewrite_text'],['faq_query_rules_title','faq_query_rules_text'],['faq_rate_limit_title','faq_rate_limit_text']]],
                  ['faq_section_performance', [['faq_cache_title','faq_cache_text']]]
                ] %}

                {% for section in faq_items %}
                <div class="ok-block ok-mb-3">
                  <div class="ok-block-title"><i data-lucide="help-circle"></i> {{ attribute(_context, section[0]) }}</div>
                  <div class="ok-block-body">
                    {% for item in section[1] %}
                    <div class="asp-faq-item{% if loop.last %} ok-mb-0{% endif %}">
                      <p class="asp-faq-title">{{ attribute(_context, item[0]) }}</p>
                      <p class="asp-faq-text ok-help">{{ attribute(_context, item[1]) }}</p>
                    </div>
                    {% endfor %}
                  </div>
                </div>
                {% endfor %}

              </div>

              {# ══ LICENSE ═════════════════════════════════════════════════ #}
              <div class="ok-layout-panel" id="tab-license">
                <div class="asp-license-center">
                  <div class="asp-license-card">

                    <div class="asp-license-brand">
                      <div class="asp-license-icon"><i data-lucide="key-round"></i></div>
                      <div class="asp-license-title">{{ heading_title }}</div>
                      <div class="asp-license-sub"><a href="https://oc-kit.com" target="_blank">oc-kit.com</a></div>
                    </div>

                    <div class="ok-block">
                      <div class="ok-block-body">

                        <div class="asp-license-badge">
                          {% if asp_license_status == 'active' %}
                            <span class="ok-badge ok-badge-success"><i data-lucide="check"></i> {{ text_license_active }}</span>
                          {% elseif asp_license_status == 'expired' %}
                            <span class="ok-badge ok-badge-warning"><i data-lucide="clock"></i> {{ text_license_expired }}</span>
                          {% elseif asp_license_status == 'invalid' %}
                            <span class="ok-badge ok-badge-danger"><i data-lucide="x-circle"></i> {{ text_license_invalid }}</span>
                          {% else %}
                            <span class="ok-badge ok-badge-default"><i data-lucide="help-circle"></i> {{ text_license_no_key }}</span>
                          {% endif %}
                        </div>

                        {% if asp_license_domain %}
                          <div class="asp-license-meta">{{ text_license_domain }}: <strong>{{ asp_license_domain }}</strong></div>
                        {% endif %}
                        {% if asp_license_expiry %}
                          <div class="asp-license-meta">{{ text_license_expiry }}: <strong>{{ asp_license_expiry }}</strong></div>
                        {% endif %}

                        <label class="form-label ok-fw-600 ok-mt-2 ok-mb-1">{{ entry_license_key }}</label>
                        <div class="ok-input-inline ok-mb-2">
                          <input type="text" name="module_oc_kit_advanced_search_pro_license_key" value="{{ module_oc_kit_advanced_search_pro_license_key }}" class="ok-input ok-flex-1" placeholder="XXXX-XXXX-XXXX-XXXX" autocomplete="off">
                        </div>
                        <p class="ok-help ok-mb-3">{{ help_license_key }}</p>

                        <a href="https://oc-kit.com" target="_blank" class="ok-btn ok-btn-default ok-btn-sm">
                          <i data-lucide="shopping-cart"></i> {{ text_license_buy }}
                        </a>

                      </div>
                    </div>

                  </div>
                </div>
              </div>

            </div>{# /ok-content #}
          </div>{# /ok-layout #}
        </div>{# /asp #}
      </form>
    </div>{# /oc-kit #}
  </div>{# /container-fluid #}
</div>{# /content #}

<script>var aspI18n = {{ asp_i18n_json }};
var aspModelOpts = {{ asp_ai_model_options_json }};
</script>
<script src="view/javascript/ockit/advanced_search_pro/assets/js/admin.js?v={{ asp_assets_v }}"></script>
{{ footer }}
